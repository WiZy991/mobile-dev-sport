{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Задачи{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Задачи</h1>
        <button type="button" class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#modalNewTask">+ Новая задача</button>
        <div class="btn-group btn-group-sm">
            {% set q = {section: 'tasks', status: 'open'} %}
            {% if clientId %}{% set q = q|merge({client_id: clientId}) %}{% endif %}
            <a href="{{ path('admin_section', q) }}" class="btn {{ statusFilter == 'open' ? 'btn-warning' : 'btn-outline-secondary' }}">Открытые</a>
            {% set q = {section: 'tasks', status: 'in_progress'} %}
            {% if clientId %}{% set q = q|merge({client_id: clientId}) %}{% endif %}
            <a href="{{ path('admin_section', q) }}" class="btn {{ statusFilter == 'in_progress' ? 'btn-info' : 'btn-outline-secondary' }}">В работе</a>
            {% set q = {section: 'tasks', status: 'done'} %}
            {% if clientId %}{% set q = q|merge({client_id: clientId}) %}{% endif %}
            <a href="{{ path('admin_section', q) }}" class="btn {{ statusFilter == 'done' ? 'btn-success' : 'btn-outline-secondary' }}">Закрытые</a>
            {% set q = {section: 'tasks', status: 'all'} %}
            {% if clientId %}{% set q = q|merge({client_id: clientId}) %}{% endif %}
            <a href="{{ path('admin_section', q) }}" class="btn {{ statusFilter == 'all' ? 'btn-primary' : 'btn-outline-secondary' }}">Все</a>
        </div>
        <div class="btn-group btn-group-sm ms-2">
            {% set baseQ = {section: 'tasks', status: statusFilter} %}
            {% if clientId %}{% set baseQ = baseQ|merge({client_id: clientId}) %}{% endif %}
            <a href="{{ path('admin_section', baseQ) }}" class="btn {{ (typeFilter|default('')) == '' ? 'btn-outline-primary' : 'btn-outline-secondary' }}">Все типы</a>
            <a href="{{ path('admin_section', baseQ|merge({type: 'task'})) }}" class="btn {{ typeFilter == 'task' ? 'btn-outline-primary' : 'btn-outline-secondary' }}">Задача</a>
            <a href="{{ path('admin_section', baseQ|merge({type: 'call'})) }}" class="btn {{ typeFilter == 'call' ? 'btn-outline-primary' : 'btn-outline-secondary' }}">Звонок</a>
            <a href="{{ path('admin_section', baseQ|merge({type: 'meeting'})) }}" class="btn {{ typeFilter == 'meeting' ? 'btn-outline-primary' : 'btn-outline-secondary' }}">Встреча</a>
        </div>
        {% if filterClient %}
            <span class="badge bg-info ms-2">Клиент: {{ filterClient.name }}
                <a href="{{ path('admin_section', {section: 'tasks', status: statusFilter}) }}" class="text-white ms-1">×</a>
            </span>
        {% endif %}
    </div>

    <div class="content-card">
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Тема</th>
                    <th>Клиент</th>
                    <th>Тип</th>
                    <th>Статус</th>
                    <th>Срок</th>
                    <th>Действия</th>
                </tr>
                </thead>
                <tbody>
                {% for task in tasks %}
                    <tr>
                        <td>{{ task.id }}</td>
                        <td>{{ task.title }}</td>
                        <td>
                            {% if task.client %}
                                <a href="{{ path('admin_client_show', {id: task.client.id}) }}" class="link-light text-decoration-none">{{ task.client.name }}</a>
                            {% else %}
                                {{ task.clientName ?? '—' }}
                            {% endif %}
                        </td>
                        <td>{{ task.type }}</td>
                        <td>
                            {% if task.status == 'open' %}
                                <span class="badge bg-warning text-dark">Открыта</span>
                            {% elseif task.status == 'in_progress' %}
                                <span class="badge bg-info">В работе</span>
                            {% else %}
                                <span class="badge bg-success">Закрыта</span>
                            {% endif %}
                        </td>
                        <td>
                            {{ task.dueAt ? task.dueAt|date('d.m.Y H:i') : '—' }}
                            {% if task.isOverdue %}
                                <span class="badge bg-danger ms-1">Просрочено</span>
                            {% endif %}
                        </td>
                        <td>
                            {% if task.status == 'open' %}
                                <form method="post" action="{{ path('admin_task_start', {id: task.id}) }}" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-info">В работу</button>
                                </form>
                            {% endif %}
                            <button type="button" class="btn btn-sm btn-outline-primary btn-edit-task"
                                    data-bs-toggle="modal" data-bs-target="#modalEditTask"
                                    data-id="{{ task.id }}"
                                    data-title="{{ task.title|e }}"
                                    data-client-id="{{ task.client ? task.client.id : '' }}"
                                    data-client-name="{{ (task.clientName ?? '')|e }}"
                                    data-due-date="{{ task.dueAt ? task.dueAt|date('Y-m-d') : '' }}"
                                    data-due-time="{{ task.dueAt ? task.dueAt|date('H:i') : '' }}"
                                    data-type="{{ task.type }}"
                                    data-status="{{ task.status }}">Изм.</button>
                            {% if task.status != 'done' %}
                                <form method="post" action="{{ path('admin_task_complete', {id: task.id}) }}" class="d-inline">
                                    <button type="submit" class="btn btn-sm btn-outline-success">Закрыть</button>
                                </form>
                            {% endif %}
                            <form method="post" action="{{ path('admin_task_delete', {id: task.id}) }}" class="d-inline" onsubmit="return confirm('Удалить задачу?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-secondary">
                            Пока нет ни одной задачи.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="modal fade" id="modalNewTask" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header">
                    <h5 class="modal-title small text-primary fw-semibold">Новая задача</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" action="{{ path('admin_task_new') }}">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label small text-secondary">Тема</label>
                                <input type="text" name="title" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Клиент</label>
                                <select name="client_id" class="form-select form-select-sm">
                                    <option value="">— Выберите —</option>
                                    {% for u in users|default([]) %}
                                        <option value="{{ u.id }}">{{ u.name }}</option>
                                    {% endfor %}
                                </select>
                                <input type="text" name="client_name" class="form-control form-control-sm mt-1" placeholder="Или введите вручную">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Дата</label>
                                <input type="date" name="due_date" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Время</label>
                                <input type="time" name="due_time" class="form-control form-control-sm">
                            </div>
                            <div class="col-12">
                                <label class="form-label small text-secondary">Тип</label>
                                <select name="type" class="form-select form-select-sm">
                                    <option value="task">Задача</option>
                                    <option value="call">Звонок</option>
                                    <option value="meeting">Встреча</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-sm btn-primary">Создать</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="modalEditTask" tabindex="-1">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header">
                    <h5 class="modal-title small text-primary fw-semibold">Редактировать задачу</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                </div>
                <form method="post" id="formEditTask" action="">
                    <div class="modal-body">
                        <input type="hidden" name="_method" value="POST">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label small text-secondary">Тема</label>
                                <input type="text" name="title" id="editTaskTitle" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Клиент</label>
                                <select name="client_id" id="editTaskClientId" class="form-select form-select-sm">
                                    <option value="">— Выберите —</option>
                                    {% for u in users|default([]) %}
                                        <option value="{{ u.id }}">{{ u.name }}</option>
                                    {% endfor %}
                                </select>
                                <input type="text" name="client_name" id="editTaskClientName" class="form-control form-control-sm mt-1" placeholder="Или введите вручную">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Дата</label>
                                <input type="date" name="due_date" id="editTaskDueDate" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Время</label>
                                <input type="time" name="due_time" id="editTaskDueTime" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small text-secondary">Тип</label>
                                <select name="type" id="editTaskType" class="form-select form-select-sm">
                                    <option value="task">Задача</option>
                                    <option value="call">Звонок</option>
                                    <option value="meeting">Встреча</option>
                                </select>
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small text-secondary">Статус</label>
                                <select name="status" id="editTaskStatus" class="form-select form-select-sm">
                                    <option value="open">Открыта</option>
                                    <option value="in_progress">В работе</option>
                                    <option value="done">Закрыта</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-sm btn-primary">Сохранить</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        document.querySelectorAll('.btn-edit-task').forEach(function(btn) {
            btn.addEventListener('click', function() {
                var id = this.dataset.id;
                document.getElementById('formEditTask').action = ('{{ path('admin_task_update', {id: 1}) }}').replace(/\/1\//, '/' + id + '/');
                document.getElementById('editTaskTitle').value = this.dataset.title;
                document.getElementById('editTaskClientId').value = this.dataset.clientId || '';
                document.getElementById('editTaskClientName').value = this.dataset.clientName || '';
                document.getElementById('editTaskDueDate').value = this.dataset.dueDate || '';
                document.getElementById('editTaskDueTime').value = this.dataset.dueTime || '';
                document.getElementById('editTaskType').value = this.dataset.type || 'task';
                document.getElementById('editTaskStatus').value = this.dataset.status || 'open';
            });
        });
    </script>
{% endblock %}

