{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Посещения{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Посещения — входы по QR</h1>
        <a href="{{ path('admin_visits_export') }}?date_from={{ dateFrom }}&date_to={{ dateTo }}" class="btn btn-sm btn-outline-success">Скачать CSV</a>
    </div>

    <div class="content-card mb-3">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small text-secondary mb-0">С</label>
                <input type="date" name="date_from" class="form-control form-control-sm" value="{{ dateFrom }}">
            </div>
            <div class="col-auto">
                <label class="form-label small text-secondary mb-0">По</label>
                <input type="date" name="date_to" class="form-control form-control-sm" value="{{ dateTo }}">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Применить</button>
            </div>
        </form>
    </div>

    <div class="content-card">
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Клиент</th>
                    <th>Телефон</th>
                    <th>Устройство</th>
                    <th>Дата и время</th>
                </tr>
                </thead>
                <tbody>
                {% for visit in visits %}
                    <tr>
                        <td>{{ visit.id }}</td>
                        <td>
                            {% if visit.user %}
                                <a href="{{ path('admin_client_show', {id: visit.user.id}) }}" class="link-light text-decoration-none">{{ visit.user.name }}</a>
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>{{ visit.user ? visit.user.phone : '—' }}</td>
                        <td>{{ visit.deviceId ?? '—' }}</td>
                        <td>{{ visit.createdAt|date('d.m.Y H:i:s') }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-secondary">
                            Пока нет ни одного посещения (входов по QR).
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

