{% extends 'admin/base.html.twig' %}

{% block title %}CRM Доброзал — Лиды{% endblock %}

{% block body %}
    <div class="content-header">
        <div>
            <h1>Лиды</h1>
            <div class="text-secondary small mt-1">Заявки с сайта, приложения, соцсетей и гостевых пропусков</div>
        </div>
    </div>

    {% if funnel is defined %}
    <div class="content-card mb-3">
        <div class="card-section-title">Воронка</div>
        <div class="crm-funnel">
            <a href="{{ path('admin_section', {section: 'leads', status: 'new'}) }}" class="crm-funnel-step {{ statusFilter == 'new' ? 'active' : '' }}">
                <div class="label">Новый</div>
                <div class="value">{{ funnel.new|default(0) }}</div>
            </a>
            <span class="crm-funnel-arrow">→</span>
            <a href="{{ path('admin_section', {section: 'leads', status: 'trial_scheduled'}) }}" class="crm-funnel-step {{ statusFilter == 'trial_scheduled' ? 'active' : '' }}">
                <div class="label">Пробное</div>
                <div class="value">{{ funnel.trial_scheduled|default(0) }}</div>
            </a>
            <span class="crm-funnel-arrow">→</span>
            <a href="{{ path('admin_section', {section: 'leads', status: 'trial_visited'}) }}" class="crm-funnel-step {{ statusFilter == 'trial_visited' ? 'active' : '' }}">
                <div class="label">Пришёл</div>
                <div class="value">{{ funnel.trial_visited|default(0) }}</div>
            </a>
            <span class="crm-funnel-arrow">→</span>
            <a href="{{ path('admin_section', {section: 'leads', status: 'converted'}) }}" class="crm-funnel-step {{ statusFilter == 'converted' ? 'active' : '' }}">
                <div class="label">Клиент</div>
                <div class="value text-success">{{ funnel.converted|default(0) }}</div>
            </a>
            <a href="{{ path('admin_section', {section: 'leads', status: 'inactive'}) }}" class="crm-funnel-step {{ statusFilter == 'inactive' ? 'active' : '' }}">
                <div class="label">Неактивен</div>
                <div class="value">{{ funnel.inactive|default(0) }}</div>
            </a>
        </div>
    </div>
    {% endif %}

    {% if sourceStats is defined %}
    <div class="content-card mb-3">
        <div class="card-section-title">По источникам</div>
        <div class="crm-source-chips mb-3">
            <a href="{{ path('admin_section', {section: 'leads', status: statusFilter}) }}" class="crm-source-chip {{ sourceFilter == '' ? 'active' : '' }}">
                Все
            </a>
            {% for key, label in lead_sources() %}
                {% if sourceStats[key]|default(0) > 0 or sourceFilter == key %}
                    <a href="{{ path('admin_section', {section: 'leads', status: statusFilter, source: key}) }}" class="crm-source-chip {{ sourceFilter == key ? 'active' : '' }}">
                        {{ label }} <strong>{{ sourceStats[key]|default(0) }}</strong>
                    </a>
                {% endif %}
            {% endfor %}
        </div>
        <form method="get" action="{{ path('admin_section', {section: 'leads'}) }}" class="row g-2 align-items-end">
            {% if statusFilter %}<input type="hidden" name="status" value="{{ statusFilter }}">{% endif %}
            <div class="col-md-3">
                <label class="form-label small text-secondary mb-0">Статус</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">Все</option>
                    <option value="new" {{ statusFilter == 'new' ? 'selected' : '' }}>Новый</option>
                    <option value="trial_scheduled" {{ statusFilter == 'trial_scheduled' ? 'selected' : '' }}>Пробное назначено</option>
                    <option value="trial_visited" {{ statusFilter == 'trial_visited' ? 'selected' : '' }}>Пробное прошло</option>
                    <option value="converted" {{ statusFilter == 'converted' ? 'selected' : '' }}>Клиент</option>
                    <option value="inactive" {{ statusFilter == 'inactive' ? 'selected' : '' }}>Неактивен</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label small text-secondary mb-0">Источник</label>
                <select name="source" class="form-select form-select-sm">
                    <option value="">Все</option>
                    {% for key, label in lead_sources() %}
                        <option value="{{ key }}" {{ sourceFilter == key ? 'selected' : '' }}>{{ label }}</option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Применить</button>
            </div>
        </form>
    </div>
    {% endif %}

    <div class="content-card mb-3">
        <div class="card-section-title">Добавить вручную</div>
        <form method="post" action="{{ path('admin_lead_new') }}">
            <div class="row g-2 align-items-end">
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Имя</label>
                    <input type="text" name="name" class="form-control form-control-sm" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Телефон</label>
                    <input type="text" name="phone" class="form-control form-control-sm" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Email</label>
                    <input type="email" name="email" class="form-control form-control-sm">
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Источник</label>
                    <select name="source" class="form-select form-select-sm" required>
                        {% for key, label in lead_sources() %}
                            <option value="{{ key }}" {{ key == 'call' ? 'selected' : '' }}>{{ label }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Комментарий</label>
                    <input type="text" name="comment" class="form-control form-control-sm">
                </div>
                <div class="col-md-1">
                    <button type="submit" class="btn btn-sm btn-primary w-100">Добавить</button>
                </div>
            </div>
        </form>
        <p class="small text-secondary mt-2 mb-0">
            Автоматически: заявки с сайта, гостевые пропуска, обращения в поддержку, регистрация по рекомендации.
        </p>
    </div>

    <div class="content-card">
        <div class="card-section-title">Список лидов</div>
        <div class="table-responsive">
            <table class="table table-sm table-dark table-hover align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Имя</th>
                    <th>Телефон</th>
                    <th>Email</th>
                    <th>Источник</th>
                    <th>Комментарий</th>
                    <th>Заметки</th>
                    <th>Статус</th>
                    <th>Создан</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for lead in leads %}
                    {% set normalized = {
                        'new':'new',
                        'in_progress':'trial_scheduled',
                        'won':'converted',
                        'lost':'inactive'
                    }[lead.status] ?? lead.status %}
                    <tr>
                        <td class="text-secondary">#{{ lead.id }}</td>
                        <td>
                            {% if lead.convertedUser %}
                                <a href="{{ path('admin_client_show', {id: lead.convertedUser.id}) }}" class="link-light text-decoration-none fw-medium">{{ lead.name }}</a>
                                <span class="badge bg-success ms-1">клиент</span>
                            {% else %}
                                <span class="fw-medium">{{ lead.name }}</span>
                            {% endif %}
                        </td>
                        <td><a href="tel:{{ (lead.phone ?? '')|replace({' ': '', '-': '', '(': '', ')': ''}) }}" class="link-light text-decoration-none">{{ lead.phone }}</a></td>
                        <td class="text-secondary">{{ lead.email ?? '—' }}</td>
                        <td>{% include 'admin/_lead_source_badge.html.twig' with {lead: lead} %}</td>
                        <td>
                            <form method="post" action="{{ path('admin_lead_comment', {id: lead.id}) }}" class="d-inline-flex align-items-center gap-1">
                                <input type="text" name="comment" class="form-control form-control-sm" style="min-width: 120px" value="{{ lead.comment ?? '' }}" placeholder="—">
                                <button type="submit" class="btn btn-sm btn-outline-secondary py-0">✓</button>
                            </form>
                        </td>
                        <td>
                            <div class="d-flex align-items-center gap-1">
                                {% if lead.notes|length > 0 %}
                                    <span class="badge bg-secondary" title="{{ lead.notes|length }} заметок">{{ lead.notes|length }}</span>
                                {% endif %}
                                <form method="post" action="{{ path('admin_lead_note_new', {id: lead.id}) }}" class="d-inline-flex">
                                    <input type="hidden" name="status_filter" value="{{ statusFilter }}">
                                    <input type="hidden" name="source_filter" value="{{ sourceFilter }}">
                                    <input type="text" name="text" class="form-control form-control-sm" style="width: 90px" placeholder="+ заметка">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary py-0 ms-1">+</button>
                                </form>
                            </div>
                        </td>
                        <td>
                            {% set label = {
                                'new':'Новый',
                                'trial_scheduled':'Пробное',
                                'trial_visited':'Пришёл',
                                'converted':'Клиент',
                                'inactive':'Неактивен'
                            }[normalized] ?? normalized %}
                            {% set badgeClass = {
                                'new':'bg-secondary',
                                'trial_scheduled':'bg-info',
                                'trial_visited':'bg-primary',
                                'converted':'bg-success',
                                'inactive':'bg-dark'
                            }[normalized] ?? 'bg-secondary' %}
                            <span class="badge {{ badgeClass }}">{{ label }}</span>
                        </td>
                        <td class="text-secondary small">{{ lead.createdAt|date('d.m.Y H:i') }}</td>
                        <td class="text-end text-nowrap">
                            {% if normalized == 'new' %}
                                <form method="post" action="{{ path('admin_lead_status', {id: lead.id}) }}" class="d-inline">
                                    <input type="hidden" name="status" value="trial_scheduled">
                                    <button type="submit" class="btn btn-outline-info btn-sm">Пробное</button>
                                </form>
                                <form method="post" action="{{ path('admin_lead_status', {id: lead.id}) }}" class="d-inline ms-1">
                                    <input type="hidden" name="status" value="inactive">
                                    <button type="submit" class="btn btn-outline-secondary btn-sm">×</button>
                                </form>
                            {% elseif normalized == 'trial_scheduled' %}
                                <form method="post" action="{{ path('admin_lead_status', {id: lead.id}) }}" class="d-inline">
                                    <input type="hidden" name="status" value="trial_visited">
                                    <button type="submit" class="btn btn-outline-primary btn-sm">Пришёл</button>
                                </form>
                            {% elseif normalized == 'trial_visited' %}
                                <form method="post" action="{{ path('admin_lead_convert', {id: lead.id}) }}" class="d-inline">
                                    <button type="submit" class="btn btn-success btn-sm">В клиента</button>
                                </form>
                            {% elseif normalized == 'converted' and lead.convertedUser %}
                                <a href="{{ path('admin_client_show', {id: lead.convertedUser.id}) }}" class="btn btn-outline-success btn-sm">Карточка</a>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="10" class="text-center text-secondary py-4">
                            Лидов пока нет. Они появятся при заявках с сайта, из приложения и других каналов.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
