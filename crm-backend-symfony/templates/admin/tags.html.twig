{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Теги{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Теги клиентов</h1>
    </div>

    <div class="content-card mb-3">
        <form method="post" action="{{ path('admin_tag_new') }}" class="row g-2 align-items-end">
            <input type="hidden" name="color" id="tagColor" value="#6c757d">
            <div class="col-auto">
                <label class="form-label small text-secondary mb-0">Название тега *</label>
                <input type="text" name="name" class="form-control form-control-sm" placeholder="VIP" required>
            </div>
            <div class="col-auto">
                <label class="form-label small text-secondary mb-0">Цвет</label>
                <input type="color" id="tagColorPicker" value="#6c757d" class="form-control form-control-color" style="width: 2.5rem; height: 1.5rem;" onchange="document.getElementById('tagColor').value=this.value">
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Создать тег</button>
            </div>
        </form>
    </div>

    <div class="content-card">
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Цвет</th>
                    <th>Клиентов</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for tag in tags %}
                    <tr>
                        <td>{{ tag.id }}</td>
                        <td>
                            <span class="badge" style="background-color: {{ tag.color ?? '#6c757d' }}">{{ tag.name }}</span>
                        </td>
                        <td><code class="small">{{ tag.color ?? '#6c757d' }}</code></td>
                        <td>{{ tag.users|length }}</td>
                        <td>
                            <form method="post" action="{{ path('admin_tag_delete', {id: tag.id}) }}" class="d-inline" onsubmit="return confirm('Удалить тег? Клиенты не будут удалены.');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-secondary">Нет тегов. Создайте тег для группировки клиентов (VIP, новичок и т.д.)</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
