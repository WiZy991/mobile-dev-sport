{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Комментарии и заметки{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Комментарии и заметки</h1>
    </div>

    <div class="content-card">
        <div class="mb-2 text-primary small fw-semibold text-uppercase">Последние заметки по клиентам</div>
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>Дата</th>
                    <th>Клиент</th>
                    <th>Заметка</th>
                </tr>
                </thead>
                <tbody>
                {% for note in notes %}
                    <tr>
                        <td class="text-nowrap">{{ note.createdAt|date('d.m.Y H:i') }}</td>
                        <td>
                            <a href="{{ path('admin_client_show', {id: note.client.id}) }}" class="link-light text-decoration-none">{{ note.client.name }}</a>
                        </td>
                        <td>{{ note.text|nl2br|slice(0, 200) }}{% if note.text|length > 200 %}...{% endif %}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center text-secondary">Пока нет заметок. Добавляйте заметки в карточках клиентов.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="content-card mt-3">
        <div class="mb-2 text-primary small fw-semibold text-uppercase">Комментарии лидов</div>
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>Дата</th>
                    <th>Лид</th>
                    <th>Комментарий</th>
                </tr>
                </thead>
                <tbody>
                {% for lead in leadsWithComments %}
                    <tr>
                        <td class="text-nowrap">—</td>
                        <td>
                            <a href="{{ path('admin_section', {section: 'leads'}) }}" class="link-light text-decoration-none">{{ lead.name }} ({{ lead.phone }})</a>
                        </td>
                        <td>{{ (lead.comment ?? '')|nl2br|slice(0, 200) }}{% if (lead.comment|default(''))|length > 200 %}...{% endif %}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="3" class="text-center text-secondary">Нет лидов с комментариями.</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
