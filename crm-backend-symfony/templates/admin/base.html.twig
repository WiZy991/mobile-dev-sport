<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}CRM {{ app.user and app.user.organization ? app.user.organization.name : 'Доброзал' }}{% endblock %}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <link href="/css/admin.css?v=6" rel="stylesheet">
    {% include 'admin/_admin_styles.html.twig' %}
</head>
<body data-dz-section="{{ current|default('') }}">
<div class="crm-bg-layer" aria-hidden="true"></div>
<div class="crm-bg-glow" aria-hidden="true"></div>

<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <div class="logo-mark">{{ app.user and app.user.organization and app.user.organization.name ? app.user.organization.name|slice(0, 1)|upper : 'Д' }}</div>
            <div>
                <p class="sidebar-brand-title">{{ app.user and app.user.organization ? app.user.organization.name : 'Доброзал' }}</p>
                <div class="sidebar-brand-sub">Панель клуба</div>
            </div>
        </div>
        <form method="get" action="{{ path('admin_search') }}" class="sidebar-search">
            <div class="search-wrap">
                <i class="bi bi-search"></i>
                <input type="text" name="q" class="form-control form-control-sm" placeholder="Поиск…" value="{{ app.request.query.get('q', '') }}">
            </div>
        </form>
        {% if app.user %}
            <div class="sidebar-user">
                <i class="bi bi-person-circle"></i>
                <span>{{ app.user.userIdentifier }}</span>
                <a href="{{ path('admin_logout') }}">Выйти</a>
            </div>
        {% endif %}
        <nav class="sidebar-nav">
            <div class="menu-section-title">Разделы</div>
            {% set icons = {
                'onboarding': 'bi-stars',
                'dashboard': 'bi-speedometer2',
                'tasks': 'bi-check2-square',
                'clients': 'bi-people',
                'leads': 'bi-funnel',
                'deals': 'bi-briefcase',
                'comments': 'bi-chat-dots',
                'schedule': 'bi-calendar3',
                'bookings': 'bi-calendar-check',
                'subscriptions': 'bi-card-checklist',
                'visits': 'bi-door-open',
                'sales': 'bi-cart3',
                'services': 'bi-bag',
                'cashdesk': 'bi-cash-stack',
                'warehouse': 'bi-box-seam',
                'analytics': 'bi-graph-up',
                'finance': 'bi-wallet2',
                'staff': 'bi-person-badge',
                'trainers': 'bi-activity',
                'mobileapps': 'bi-phone',
                'app_support': 'bi-headset',
                'promocodes': 'bi-ticket-perforated',
                'promotions': 'bi-megaphone',
                'settings': 'bi-gear',
                'documents': 'bi-file-earmark-text',
                'tags': 'bi-tags',
                'selfservice': 'bi-qr-code',
                'messengers': 'bi-chat-left-text',
                'calls': 'bi-telephone',
                'crm_staff': 'bi-shield-lock',
                'franchise': 'bi-building'
            } %}
            {% for key, label in menu %}
                <a href="{% if key == 'dashboard' %}{{ path('admin_dashboard') }}{% elseif key == 'crm_staff' %}{{ path('admin_crm_staff_index') }}{% elseif key == 'franchise' %}{{ path('admin_franchise_list') }}{% elseif key == 'platform' %}{{ path('admin_platform_organizations') }}{% else %}{{ path('admin_section', {section: key}) }}{% endif %}"
                   class="menu-item {{ current == key ? 'active' : '' }}"
                   data-dz-nav="{{ key }}">
                    <i class="bi {{ icons[key]|default('bi-circle') }}"></i>
                    <span>{{ label }}</span>
                </a>
            {% endfor %}
        </nav>
    </aside>
    <main class="content">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show crm-alert" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </main>
</div>
{% include 'admin/partials/_zalka_tour_styles.html.twig' %}
{% include 'admin/partials/_zalka_tour_overlay.html.twig' %}
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
<script charset="UTF-8">{% include 'admin/partials/_admin_crm_select_boot.js.twig' %}</script>
<script charset="UTF-8">{% include 'admin/partials/_dobrozal_onboarding_boot.js.twig' %}</script>
</body>
</html>
