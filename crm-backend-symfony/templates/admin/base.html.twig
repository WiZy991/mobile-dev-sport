<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>{% block title %}CRM FitnessClub{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body {
            background-color: #14161a;
            color: #f5f5f5;
            font-family: system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        }
        .layout {
            display: flex;
            min-height: 100vh;
        }
        .sidebar {
            width: 260px;
            background: #1c1f26;
            border-right: 1px solid #2b3038;
            padding: 16px 0;
        }
        .menu-section-title {
            padding: 8px 20px;
            text-transform: uppercase;
            font-size: 11px;
            color: #727887;
        }
        .menu-item {
            display: block;
            padding: 8px 20px;
            color: #d0d4e0;
            text-decoration: none;
            font-size: 14px;
        }
        .menu-item:hover {
            background-color: #262b34;
            color: #ffffff;
        }
        .menu-item.active {
            background: linear-gradient(90deg, #ff9800, #ff5722);
            color: #ffffff;
        }
        .content {
            flex: 1;
            padding: 20px 28px;
        }
        .content-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }
        .content-card {
            background: #1c1f26;
            border-radius: 10px;
            padding: 16px 20px;
            border: 1px solid #262b34;
        }
        .badge-status {
            border-radius: 999px;
            padding: 2px 10px;
            font-size: 11px;
        }
    </style>
</head>
<body>
<div class="layout">
    <aside class="sidebar">
        <form method="get" action="{{ path('admin_search') }}" class="p-2">
            <input type="text" name="q" class="form-control form-control-sm" placeholder="Поиск..." value="{{ app.request.query.get('q', '') }}">
        </form>
        {% if app.user %}
            <div class="px-3 py-2 small text-secondary border-bottom border-secondary border-opacity-25">
                {{ app.user.userIdentifier }}
                <a href="{{ path('admin_logout') }}" class="d-block mt-1 text-warning text-decoration-none">Выйти</a>
            </div>
        {% endif %}
        <div class="menu-section-title">Навигация</div>
        {% for key, label in menu %}
            <a href="{% if key == 'dashboard' %}{{ path('admin_dashboard') }}{% elseif key == 'crm_staff' %}{{ path('admin_crm_staff_index') }}{% elseif key == 'franchise' %}{{ path('admin_franchise_list') }}{% else %}{{ path('admin_section', {section: key}) }}{% endif %}"
               class="menu-item {{ current == key ? 'active' : '' }}">
                {{ label }}
            </a>
        {% endfor %}
    </aside>
    <main class="content">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

