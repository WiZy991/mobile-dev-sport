<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}CRM Доброзал{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    {# Без asset() — добавим cache-bust, чтобы браузер не держал старую версию #}
    <link href="/css/admin.css?v={{ app.request.server.get('REQUEST_TIME') }}" rel="stylesheet">
    {# Минимальный фолбэк, если /css/admin.css не отдался веб-сервером #}
    <style>
        body{background:#0f1115;color:#eef1f6;font-family:"Segoe UI",system-ui,-apple-system,BlinkMacSystemFont,sans-serif;margin:0}
        .layout{display:flex;min-height:100vh}
        .sidebar{width:252px;background:#11141a;border-right:1px solid #222833}
        .content{flex:1;padding:24px 28px}
        .menu-item{display:block;padding:8px 16px;color:#c5cad6;text-decoration:none}
        .menu-item:hover{background:#242a35;color:#fff}
        .content-card{background:#1c2029;border:1px solid #222833;border-radius:12px;padding:18px 20px}
    </style>
</head>
<body>
<div class="layout">
    <aside class="sidebar">
        <div class="sidebar-brand">
            <p class="sidebar-brand-title">Доброзал</p>
            <div class="sidebar-brand-sub">Панель управления клубом</div>
        </div>
        <form method="get" action="{{ path('admin_search') }}" class="sidebar-search">
            <input type="text" name="q" class="form-control form-control-sm" placeholder="Поиск клиентов, лидов…" value="{{ app.request.query.get('q', '') }}">
        </form>
        {% if app.user %}
            <div class="sidebar-user">
                <i class="bi bi-person-circle me-1"></i> {{ app.user.userIdentifier }}
                <a href="{{ path('admin_logout') }}" class="d-block mt-1">Выйти</a>
            </div>
        {% endif %}
        <div class="menu-section-title">Разделы</div>
        {% for key, label in menu %}
            <a href="{% if key == 'dashboard' %}{{ path('admin_dashboard') }}{% elseif key == 'crm_staff' %}{{ path('admin_crm_staff_index') }}{% elseif key == 'franchise' %}{{ path('admin_franchise_list') }}{% else %}{{ path('admin_section', {section: key}) }}{% endif %}"
               class="menu-item {{ current == key ? 'active' : '' }}">
                {{ label }}
            </a>
        {% endfor %}
    </aside>
    <main class="content">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
                <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show" role="alert">
                    {{ message }}
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            {% endfor %}
        {% endfor %}
        {% block body %}{% endblock %}
    </main>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
