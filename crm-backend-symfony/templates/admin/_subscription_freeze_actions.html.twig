{% if admin_can_mutate() %}
    {% if subscription_can_freeze(sub) %}
        {% set maxDays = subscription_freeze_days_left(sub) %}
        {% set defaultDays = maxDays < 7 ? maxDays : 7 %}
        <form method="post" action="{{ path('admin_subscription_freeze', {id: sub.id}) }}" class="d-inline-flex flex-wrap gap-1 align-items-center">
            {% if return_to is defined and return_to %}
                <input type="hidden" name="return_to" value="{{ return_to }}">
            {% endif %}
            {% if return_status is defined and return_status %}
                <input type="hidden" name="return_status" value="{{ return_status }}">
            {% endif %}
            <input type="number" name="days" min="1" max="{{ maxDays }}" value="{{ defaultDays }}" class="form-control form-control-sm" style="width:4.5rem" required title="Дней заморозки">
            <button type="submit" class="btn btn-sm btn-outline-warning">Заморозить</button>
        </form>
    {% elseif sub.status == 'frozen' %}
        <form method="post" action="{{ path('admin_subscription_unfreeze', {id: sub.id}) }}" class="d-inline">
            {% if return_to is defined and return_to %}
                <input type="hidden" name="return_to" value="{{ return_to }}">
            {% endif %}
            {% if return_status is defined and return_status %}
                <input type="hidden" name="return_status" value="{{ return_status }}">
            {% endif %}
            <button type="submit" class="btn btn-sm btn-outline-success">Разморозить</button>
        </form>
    {% else %}
        <span class="text-secondary small">—</span>
    {% endif %}
{% else %}
    —
{% endif %}
