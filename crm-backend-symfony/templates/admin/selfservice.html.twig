{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Самообслуживание{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Самообслуживание — вход по QR</h1>
        <a href="{{ path('admin_selfservice_export') }}?date_from={{ dateFrom }}&date_to={{ dateTo }}{% if resultFilter %}&result={{ resultFilter }}{% endif %}" class="btn btn-sm btn-outline-primary">Экспорт CSV</a>
    </div>

    <div class="content-card mb-3">
        <form method="get" action="{{ path('admin_section', {section: 'selfservice'}) }}" class="row g-2 align-items-end">
            <div class="col-auto">
                <label class="form-label small text-secondary mb-0">С</label>
                <input type="date" name="date_from" class="form-control form-control-sm" value="{{ dateFrom }}">
            </div>
            <div class="col-auto">
                <label class="form-label small text-secondary mb-0">По</label>
                <input type="date" name="date_to" class="form-control form-control-sm" value="{{ dateTo }}">
            </div>
            <div class="col-auto">
                <label class="form-label small text-secondary mb-0">Результат</label>
                <select name="result" class="form-select form-select-sm">
                    <option value="">Все</option>
                    <option value="granted" {{ resultFilter == 'granted' ? 'selected' : '' }}>Разрешён</option>
                    <option value="denied" {{ resultFilter == 'denied' ? 'selected' : '' }}>Отклонён</option>
                </select>
            </div>
            <div class="col-auto">
                <button type="submit" class="btn btn-sm btn-primary">Применить</button>
            </div>
        </form>
    </div>

    <div class="content-card">
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Дата</th>
                    <th>Клиент</th>
                    <th>Устройство</th>
                    <th>Результат</th>
                    <th>Причина</th>
                </tr>
                </thead>
                <tbody>
                {% for log in logs %}
                    <tr>
                        <td>{{ log.id }}</td>
                        <td>{{ log.createdAt|date('d.m.Y H:i:s') }}</td>
                        <td>
                            {% if log.user %}
                                {{ log.user.name }} ({{ log.user.phone }})
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>{{ log.deviceId ?? '—' }}</td>
                        <td>
                            {% if log.result == 'granted' %}
                                <span class="badge bg-success">Разрешён</span>
                            {% else %}
                                <span class="badge bg-danger">Отклонён</span>
                            {% endif %}
                        </td>
                        <td>{{ log.reason ?? '—' }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="6" class="text-center text-secondary">
                            Логов входа по QR пока нет.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}

