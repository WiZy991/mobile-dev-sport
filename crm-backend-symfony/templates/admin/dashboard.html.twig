{% extends 'admin/base.html.twig' %}

{% block title %}CRM Доброзал — Дашборд{% endblock %}

{% block body %}
    <div class="content-header" data-dz-tour="dashboard-header">
        <div>
            <h1>Дашборд</h1>
            <div class="text-secondary small">Сегодня {{ "now"|date("d.m.Y") }}</div>
        </div>
        <a href="{{ path('admin_section', {section: 'onboarding'}) }}" class="btn btn-sm btn-outline-primary">
            <i class="bi bi-stars me-1"></i> Обучение
        </a>
    </div>

    <div class="content-card mb-3 crm-onboarding-banner">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div class="d-flex align-items-center gap-3">
                <img src="{{ dz_mascot_face_url('happy') }}" class="dz-dashboard-mascot-img" width="56" height="56" alt="" aria-hidden="true">
                <div>
                    <div class="fw-bold mb-1">Пройдите обучение по CRM</div>
                    <div class="text-secondary small">Интерактивный тур по CRM: Тренер подсвечивает реальные кнопки и разделы.</div>
                </div>
            </div>
            <a href="{{ path('admin_section', {section: 'onboarding'}) }}" class="btn btn-primary btn-sm">Начать обучение</a>
        </div>
    </div>

    {% if admin_can_mutate() %}
    <div class="content-card mb-3">
        <div class="card-section-title">Быстрые действия</div>
        <div class="row g-2">
            <div class="col-6 col-md-3 col-lg-2">
                <a href="{{ path('admin_client_new') }}" class="crm-quick-action">
                    <div class="num">1</div>
                    <div class="small">Новый клиент</div>
                </a>
            </div>

            {% set quickActions = [
                {'label': 'Новый лид', 'type': 'modal', 'target': '#modalNewLead'},
                {'label': 'Новая продажа', 'type': 'modal', 'target': '#modalNewSale'},
                {'label': 'Посещения', 'route': 'admin_section', 'params': {'section': 'visits'}},
                {'label': 'Новая задача', 'type': 'modal', 'target': '#modalNewTask'},
                {'label': 'Аналитика', 'route': 'admin_section', 'params': {'section': 'analytics'}},
                {'label': 'Финансы', 'route': 'admin_section', 'params': {'section': 'finance'}},
                {'label': 'Настройки', 'route': 'admin_section', 'params': {'section': 'settings'}},
                {'label': 'Поддержка', 'route': 'admin_section', 'params': {'section': 'messengers'}}
            ] %}

            {% for action in quickActions %}
                <div class="col-6 col-md-3 col-lg-2">
                    {% if action.type is defined and action.type == 'modal' %}
                        <button type="button" class="crm-quick-action w-100 border-0" data-bs-toggle="modal" data-bs-target="{{ action.target }}">
                    {% else %}
                        <a href="{{ path(action.route, action.params) }}" class="crm-quick-action">
                    {% endif %}
                            <div class="num">{{ loop.index + 1 }}</div>
                            <div class="small">{{ action.label }}</div>
                    {% if action.type is defined and action.type == 'modal' %}
                        </button>
                    {% else %}
                        </a>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>
    {% endif %}

    <div class="row g-3" data-dz-tour="dashboard-stats">
        <div class="col-6 col-md-2">
            {% if menu.clients is defined %}
            <a href="{{ path('admin_section', {section: 'clients'}) }}" class="text-decoration-none text-reset">
            {% endif %}
                <div class="content-card h-100" {% if menu.clients is defined %}style="cursor: pointer;"{% endif %}>
                    <div class="text-secondary small mb-1">Активные клиенты</div>
                    <div class="h4 mb-0">{{ stats.clients }}</div>
                </div>
            {% if menu.clients is defined %}
            </a>
            {% endif %}
        </div>
        <div class="col-6 col-md-2">
            {% if menu.leads is defined %}
            <a href="{{ path('admin_section', {section: 'leads'}) }}" class="text-decoration-none text-reset">
            {% endif %}
                <div class="content-card h-100" {% if menu.leads is defined %}style="cursor: pointer;"{% endif %}>
                    <div class="text-secondary small mb-1">Открытые лиды</div>
                    <div class="h4 mb-0">{{ stats.leads }}</div>
                </div>
            {% if menu.leads is defined %}
            </a>
            {% endif %}
        </div>
        <div class="col-6 col-md-2">
            {% if menu.schedule is defined %}
            <a href="{{ path('admin_section', {section: 'schedule'}) }}?date={{ "now"|date("Y-m-d") }}" class="text-decoration-none text-reset">
            {% endif %}
                <div class="content-card h-100" {% if menu.schedule is defined %}style="cursor: pointer;"{% endif %}>
                    <div class="text-secondary small mb-1">Тренировки сегодня</div>
                    <div class="h4 mb-0">{{ stats.trainingsToday }}</div>
                </div>
            {% if menu.schedule is defined %}
            </a>
            {% endif %}
        </div>
        <div class="col-6 col-md-2">
            {% if menu.visits is defined %}
            <a href="{{ path('admin_section', {section: 'visits'}) }}" class="text-decoration-none text-reset">
            {% endif %}
                <div class="content-card h-100" {% if menu.visits is defined %}style="cursor: pointer;"{% endif %}>
                    <div class="text-secondary small mb-1">Посещений сегодня</div>
                    <div class="h4 mb-0">{{ stats.visitsToday|default(0) }}</div>
                </div>
            {% if menu.visits is defined %}
            </a>
            {% endif %}
        </div>
        <div class="col-6 col-md-2">
            {% if menu.visits is defined %}
            <a href="{{ path('admin_section', {section: 'visits'}) }}" class="text-decoration-none text-reset">
            {% endif %}
                <div class="content-card h-100" {% if menu.visits is defined %}style="cursor: pointer;"{% endif %}>
                    <div class="text-secondary small mb-1">Сейчас в зале</div>
                    <div class="h4 mb-0">
                        {% if stats.currentlyInside|default(0) > 0 %}
                            <span class="text-success">{{ stats.currentlyInside }}</span>
                        {% else %}
                            <span class="text-secondary">0</span>
                        {% endif %}
                    </div>
                </div>
            {% if menu.visits is defined %}
            </a>
            {% endif %}
        </div>
        <div class="col-6 col-md-2">
            {% if menu.cashdesk is defined %}
            <a href="{{ path('admin_section', {section: 'cashdesk'}) }}?date={{ "now"|date("Y-m-d") }}" class="text-decoration-none text-reset">
            {% endif %}
                <div class="content-card h-100" {% if menu.cashdesk is defined %}style="cursor: pointer;"{% endif %}>
                    <div class="text-secondary small mb-1">Выручка за день</div>
                    <div class="h4 mb-0">
                        {% if stats.revenueToday %}
                            {{ stats.revenueToday|number_format(0, '', ' ') }} ₽
                        {% else %}
                            0 ₽
                        {% endif %}
                    </div>
                </div>
            {% if menu.cashdesk is defined %}
            </a>
            {% endif %}
        </div>
        <div class="col-6 col-md-2">
            {% if menu.finance is defined %}
            <a href="{{ path('admin_section', {section: 'finance'}) }}" class="text-decoration-none text-reset">
            {% endif %}
                <div class="content-card h-100" {% if menu.finance is defined %}style="cursor: pointer;"{% endif %}>
                    <div class="text-secondary small mb-1">Выручка за месяц</div>
                    <div class="h4 mb-0">
                        {% if stats.revenueMonth is defined and stats.revenueMonth %}
                            {{ stats.revenueMonth|number_format(0, '', ' ') }} ₽
                        {% else %}
                            0 ₽
                        {% endif %}
                    </div>
                </div>
            {% if menu.finance is defined %}
            </a>
            {% endif %}
        </div>
    </div>

    {% if menu.leads is defined and funnelLeads is defined and (funnelLeads.new > 0 or funnelLeads.converted > 0) %}
    <div class="content-card mt-3 mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-primary small fw-semibold text-uppercase">Лиды</span>
            <a href="{{ path('admin_section', {section: 'leads'}) }}" class="btn btn-sm btn-outline-primary">Воронка →</a>
        </div>
        <div class="d-flex gap-3">
            <div><span class="text-secondary small">Новых:</span> <strong>{{ funnelLeads.new }}</strong></div>
            <div><span class="text-secondary small">Конвертировано:</span> <strong class="text-success">{{ funnelLeads.converted }}</strong></div>
        </div>
    </div>
    {% endif %}

    {% if upcomingTrainings|default([])|length > 0 %}
    <div class="content-card mt-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2 class="h6 mb-0">Ближайшие тренировки</h2>
            <a href="{{ path('admin_section', {section: 'schedule'}) }}?date={{ "now"|date("Y-m-d") }}" class="btn btn-sm btn-outline-primary">Расписание</a>
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead><tr><th>Название</th><th>Тренер</th><th>Время</th><th>Мест</th><th>Записано</th></tr></thead>
                <tbody>
                {% for t in upcomingTrainings %}
                    <tr>
                        <td>{{ t.name }}</td>
                        <td>{{ t.trainerName ?? '—' }}</td>
                        <td>{{ t.startAt|date('d.m H:i') }}</td>
                        <td>{{ t.maxParticipants }}</td>
                        <td>{{ t.currentParticipants }}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

    {% if menu.tasks is defined %}
    <div class="mt-4 content-card">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2 class="h6 mb-0">Задачи</h2>
            {% if tasks is defined and tasks|length > 0 %}
                <span class="badge bg-danger">{{ tasks|length }} новых</span>
            {% else %}
                <span class="text-secondary small">Нет открытых задач</span>
            {% endif %}
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>Тема</th>
                    <th>Клиент</th>
                    <th>Срок</th>
                    <th>Статус</th>
                </tr>
                </thead>
                <tbody>
                {% if tasks is defined and tasks|length > 0 %}
                    {% for task in tasks %}
                        <tr>
                            <td>{{ task.title }}{% if task.isOverdue %} <span class="badge bg-danger">Просрочено</span>{% endif %}</td>
                            <td>
                                {% if task.client %}
                                    <a href="{{ path('admin_client_show', {id: task.client.id}) }}" class="link-light text-decoration-none">{{ task.client.name }}</a>
                                {% else %}
                                    {{ task.clientName ?? '—' }}
                                {% endif %}
                            </td>
                            <td>{{ task.dueAt ? task.dueAt|date('d.m.Y H:i') : '—' }}</td>
                            <td>
                                <span class="badge-status bg-warning text-dark">
                                    {{ task.status }}
                                </span>
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-secondary">
                            Открытых задач нет.
                        </td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}
    
    {% if admin_can_mutate() %}
    {# Модальное окно "Новый лид" #}
    <div class="modal fade" id="modalNewLead" tabindex="-1" aria-labelledby="modalNewLeadLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header">
                    <h5 class="modal-title small text-primary fw-semibold" id="modalNewLeadLabel">Новый лид</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <form method="post" action="/admin/leads/new">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Имя</label>
                                <input type="text" name="name" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Телефон</label>
                                <input type="text" name="phone" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">E-mail</label>
                                <input type="email" name="email" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Источник</label>
                                <select name="source" class="form-select form-select-sm">
                                    {% for key, label in lead_sources() %}
                                        <option value="{{ key }}" {{ key == 'call' ? 'selected' : '' }}>{{ label }}</option>
                                    {% endfor %}
                                </select>
                            </div>
                            <div class="col-12">
                                <label class="form-label small text-secondary">Комментарий</label>
                                <textarea name="comment" class="form-control form-control-sm" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-sm btn-primary">Создать лид</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Модальное окно "Новая задача" #}
    <div class="modal fade" id="modalNewTask" tabindex="-1" aria-labelledby="modalNewTaskLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header">
                    <h5 class="modal-title small text-primary fw-semibold" id="modalNewTaskLabel">Новая задача</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <form method="post" action="/admin/tasks/new">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label small text-secondary">Тема</label>
                                <input type="text" name="title" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Клиент</label>
                                <select name="client_id" class="form-select form-select-sm">
                                    <option value="">— Выберите —</option>
                                    {% for u in users|default([]) %}
                                        <option value="{{ u.id }}">{{ u.name }}</option>
                                    {% endfor %}
                                </select>
                                <input type="text" name="client_name" class="form-control form-control-sm mt-1" placeholder="Или введите вручную">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Дата окончания</label>
                                <input type="date" name="due_date" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Время</label>
                                <input type="time" name="due_time" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small text-secondary">Тип</label>
                                <select name="type" class="form-select form-select-sm">
                                    <option value="task">Задача</option>
                                    <option value="call">Звонок</option>
                                    <option value="meeting">Встреча</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-sm btn-primary">Создать задачу</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Модальное окно "Новая продажа" #}
    <div class="modal fade" id="modalNewSale" tabindex="-1" aria-labelledby="modalNewSaleLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header">
                    <h5 class="modal-title small text-primary fw-semibold" id="modalNewSaleLabel">Новая продажа</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <form method="post" action="/admin/sales/new">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Клиент</label>
                                <select name="user_id" class="form-select form-select-sm" id="saleUserSelect">
                                    <option value="">— Выберите клиента —</option>
                                    {% for u in users|default([]) %}
                                        <option value="{{ u.id }}">{{ u.name }}{% if u.email %} ({{ u.email }}){% endif %}</option>
                                    {% endfor %}
                                </select>
                                <input type="text" name="client_name" class="form-control form-control-sm mt-1" id="saleClientName" placeholder="Или введите имя вручную (если клиента нет в списке)">
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Услуга / товар</label>
                                <select name="product_id" class="form-select form-select-sm" id="dashboardProductSelect">
                                    <option value="">— Выберите из каталога —</option>
                                    {% for p in products|default([]) %}
                                        <option value="{{ p.id }}" data-name="{{ p.name }}" data-price="{{ p.price }}">{{ p.name }} — {{ p.price|number_format(0, '', ' ') }} ₽</option>
                                    {% endfor %}
                                </select>
                                <input type="text" name="product_name" class="form-control form-control-sm mt-1" id="dashboardProductName" placeholder="Или введите вручную" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Кол-во</label>
                                <input type="number" name="quantity" class="form-control form-control-sm" value="1" min="1">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Цена, ₽</label>
                                <input type="number" step="0.01" name="price" class="form-control form-control-sm" id="dashboardPrice" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Оплата</label>
                                <select name="payment_method" class="form-select form-select-sm">
                                    <option value="cash">Наличные</option>
                                    <option value="card">Карта</option>
                                    <option value="bonus">Бонусы</option>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Промокод</label>
                                <input type="text" name="promo_code" class="form-control form-control-sm" placeholder="SUMMER20">
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-sm btn-primary">Провести продажу</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
    {% endif %}

    <script>
        document.getElementById('dashboardProductSelect')?.addEventListener('change', function() {
            const opt = this.options[this.selectedIndex];
            const nameInput = document.getElementById('dashboardProductName');
            const priceInput = document.getElementById('dashboardPrice');
            if (opt.value && opt.dataset.name) {
                nameInput.value = opt.dataset.name;
                priceInput.value = opt.dataset.price;
                nameInput.removeAttribute('required');
            } else {
                nameInput.value = '';
                nameInput.setAttribute('required', 'required');
            }
        });
    </script>
{% endblock %}

