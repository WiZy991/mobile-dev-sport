{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Дашборд{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Дашборд</h1>
        <span class="text-secondary small">Сегодня {{ "now"|date("d.m.Y") }}</span>
    </div>

    <div class="content-card mb-3">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <span class="text-primary small fw-semibold text-uppercase">Быстрые действия</span>
        </div>
        <div class="row g-2">
            <div class="col-6 col-md-3 col-lg-2">
                <button type="button"
                        class="d-block w-100 text-center p-3 rounded-3 text-decoration-none btn btn-link border-0"
                        style="background: #212633; border: 1px solid #2f3645;"
                        data-bs-toggle="modal" data-bs-target="#modalNewClient">
                    <div class="mb-2">
                        <span class="badge bg-primary-subtle text-primary border border-primary"
                              style="border-radius: 999px; font-size: 11px;">
                            1
                        </span>
                    </div>
                    <div class="small text-light">
                        Новый клиент
                    </div>
                </button>
            </div>

            {% set quickActions = [
                {'label': 'Новый лид', 'type': 'modal', 'target': '#modalNewLead'},
                {'label': 'Новая продажа', 'type': 'modal', 'target': '#modalNewSale'},
                {'label': 'Массовое обслуживание', 'route': 'admin_section', 'params': {'section': 'visits'}} ,
                {'label': 'Новая задача', 'type': 'modal', 'target': '#modalNewTask'},
                {'label': 'Аналитика', 'route': 'admin_section', 'params': {'section': 'analytics'}},
                {'label': 'Справка', 'route': 'admin_section', 'params': {'section': 'settings'}},
                {'label': 'Чат поддержки', 'route': 'admin_section', 'params': {'section': 'messengers'}}
            ] %}

            {% for action in quickActions %}
                <div class="col-6 col-md-3 col-lg-2">
                    {% if action.type is defined and action.type == 'modal' %}
                        <button type="button"
                                class="d-block w-100 text-center p-3 rounded-3 text-decoration-none btn btn-link border-0"
                                style="background: #212633; border: 1px solid #2f3645;"
                                data-bs-toggle="modal" data-bs-target="{{ action.target }}">
                    {% else %}
                        <a href="{{ path(action.route, action.params) }}"
                           class="d-block text-center p-3 rounded-3 text-decoration-none"
                           style="background: #212633; border: 1px solid #2f3645;">
                    {% endif %}
                        <div class="mb-2">
                            <span class="badge bg-primary-subtle text-primary border border-primary"
                                  style="border-radius: 999px; font-size: 11px;">
                                {{ loop.index + 1 }}
                            </span>
                        </div>
                        <div class="small text-light">
                            {{ action.label }}
                        </div>
                    {% if action.type is defined and action.type == 'modal' %}
                        </button>
                    {% else %}
                        </a>
                    {% endif %}
                </div>
            {% endfor %}
        </div>
    </div>

    <div class="row g-3">
        <div class="col-md-3">
            <div class="content-card">
                <div class="text-secondary small mb-1">Активные клиенты</div>
                <div class="h4 mb-0">{{ stats.clients }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="content-card">
                <div class="text-secondary small mb-1">Открытые лиды</div>
                <div class="h4 mb-0">{{ stats.leads }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="content-card">
                <div class="text-secondary small mb-1">Тренировки сегодня</div>
                <div class="h4 mb-0">{{ stats.trainingsToday }}</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="content-card">
                <div class="text-secondary small mb-1">Выручка за день</div>
                <div class="h4 mb-0">
                    {% if stats.revenueToday %}
                        {{ stats.revenueToday|number_format(0, '', ' ') }} ₽
                    {% else %}
                        0 ₽
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    <div class="mt-4 content-card">
        <div class="d-flex justify-content-between align-items-center mb-2">
            <h2 class="h6 mb-0">Задачи</h2>
            {% if tasks is defined and tasks|length > 0 %}
                <span class="badge bg-danger">{{ tasks|length }} новых</span>
            {% else %}
                <span class="text-secondary small">Нет открытых задач</span>
            {% endif %}
        </div>
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>Тема</th>
                    <th>Клиент</th>
                    <th>Срок</th>
                    <th>Статус</th>
                </tr>
                </thead>
                <tbody>
                {% if tasks is defined and tasks|length > 0 %}
                    {% for task in tasks %}
                        <tr>
                            <td>{{ task.title }}</td>
                            <td>{{ task.clientName }}</td>
                            <td>{{ task.dueAt|date('d.m.Y H:i') }}</td>
                            <td>
                                <span class="badge-status bg-warning text-dark">
                                    {{ task.status }}
                                </span>
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="4" class="text-center text-secondary">
                            Открытых задач нет.
                        </td>
                    </tr>
                {% endif %}
                </tbody>
            </table>
        </div>
    </div>
    
    {# Модальное окно "Новый клиент" #}
    <div class="modal fade" id="modalNewClient" tabindex="-1" aria-labelledby="modalNewClientLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header">
                    <h5 class="modal-title small text-primary fw-semibold" id="modalNewClientLabel">Новый клиент</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <form method="post" action="/admin/clients/new">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Имя</label>
                                <input type="text" name="name" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Телефон</label>
                                <input type="text" name="phone" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">E-mail</label>
                                <input type="email" name="email" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Бонусы (начальный баланс)</label>
                                <input type="number" name="bonus_points" class="form-control form-control-sm" value="0">
                            </div>
                            <div class="col-12">
                                <label class="form-label small text-secondary">Заметка</label>
                                <textarea name="note" class="form-control form-control-sm" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-sm btn-primary">Создать клиента</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Модальное окно "Новый лид" #}
    <div class="modal fade" id="modalNewLead" tabindex="-1" aria-labelledby="modalNewLeadLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header">
                    <h5 class="modal-title small text-primary fw-semibold" id="modalNewLeadLabel">Новый лид</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <form method="post" action="/admin/leads/new">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Имя</label>
                                <input type="text" name="name" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Телефон</label>
                                <input type="text" name="phone" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">E-mail</label>
                                <input type="email" name="email" class="form-control form-control-sm">
                            </div>
                            <div class="col-12">
                                <label class="form-label small text-secondary">Комментарий</label>
                                <textarea name="comment" class="form-control form-control-sm" rows="2"></textarea>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-sm btn-primary">Создать лид</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    {# Модальное окно "Новая задача" #}
    <div class="modal fade" id="modalNewTask" tabindex="-1" aria-labelledby="modalNewTaskLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header">
                    <h5 class="modal-title small text-primary fw-semibold" id="modalNewTaskLabel">Новая задача</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <form method="post" action="/admin/tasks/new">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label small text-secondary">Тема</label>
                                <input type="text" name="title" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Клиент</label>
                                <input type="text" name="client_name" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Дата окончания</label>
                                <input type="date" name="due_date" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Время</label>
                                <input type="time" name="due_time" class="form-control form-control-sm">
                            </div>
                            <div class="col-md-4">
                                <label class="form-label small text-secondary">Тип</label>
                                <select name="type" class="form-select form-select-sm">
                                    <option value="task">Задача</option>
                                    <option value="call">Звонок</option>
                                    <option value="meeting">Встреча</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-sm btn-primary">Создать задачу</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    {# Модальное окно "Новая продажа" #}
    <div class="modal fade" id="modalNewSale" tabindex="-1" aria-labelledby="modalNewSaleLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content bg-dark border-secondary">
                <div class="modal-header">
                    <h5 class="modal-title small text-primary fw-semibold" id="modalNewSaleLabel">Новая продажа</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"
                            aria-label="Close"></button>
                </div>
                <form method="post" action="/admin/sales/new">
                    <div class="modal-body">
                        <div class="row g-3">
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Клиент</label>
                                <input type="text" name="client_name" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small text-secondary">Услуга / товар</label>
                                <input type="text" name="product_name" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Кол-во</label>
                                <input type="number" name="quantity" class="form-control form-control-sm" value="1" min="1">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Цена, ₽</label>
                                <input type="number" step="0.01" name="price" class="form-control form-control-sm" required>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small text-secondary">Оплата</label>
                                <select name="payment_method" class="form-select form-select-sm">
                                    <option value="cash">Наличные</option>
                                    <option value="card">Карта</option>
                                    <option value="bonus">Бонусы</option>
                                </select>
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Отмена</button>
                        <button type="submit" class="btn btn-sm btn-primary">Провести продажу</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
{% endblock %}

