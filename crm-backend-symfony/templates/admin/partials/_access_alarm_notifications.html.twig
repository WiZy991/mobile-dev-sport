{% if app.user is instanceof('App\\Entity\\StaffUser') %}
    {% set dz_alarm_roles = app.user.roles %}
    {% set dz_show_alarms = 'ROLE_SUPER_ADMIN' in dz_alarm_roles or 'ROLE_ADMIN' in dz_alarm_roles or 'ROLE_MANAGER' in dz_alarm_roles or 'ROLE_CLUB_ALL' in dz_alarm_roles %}
    {% if not dz_show_alarms %}
        {% for r in dz_alarm_roles %}
            {% if r starts with 'ROLE_CLUB_' %}
                {% set dz_show_alarms = true %}
            {% endif %}
        {% endfor %}
    {% endif %}
    {% if dz_show_alarms %}
        <div class="sidebar-alarms" id="dz-access-alarms-root"
             data-poll-url="{{ path('admin_api_access_alarms') }}"
             data-user-id="{{ app.user.id }}">
            <button type="button" class="alarm-bell-btn" id="dz-alarm-bell" aria-label="Тревоги прохода" aria-expanded="false">
                <i class="bi bi-bell-fill"></i>
                <span class="alarm-bell-badge d-none" id="dz-alarm-badge">0</span>
            </button>
            <div class="alarm-dropdown d-none" id="dz-alarm-dropdown" role="dialog" aria-label="Тревоги прохода">
                <div class="alarm-dropdown-head">
                    <span class="fw-semibold">Тревоги прохода</span>
                    <button type="button" class="btn btn-link btn-sm p-0 alarm-mark-read" id="dz-alarm-mark-read">Прочитать все</button>
                </div>
                <div class="alarm-desktop-row">
                    <button type="button" class="btn btn-sm btn-outline-warning w-100" id="dz-alarm-enable-desktop">
                        <i class="bi bi-pc-display-horizontal me-1"></i> Уведомления на рабочем столе
                    </button>
                </div>
                <div class="alarm-list" id="dz-alarm-list">
                    <div class="alarm-list-empty text-secondary small">Загрузка…</div>
                </div>
                <a href="{{ path('admin_franchise_list') }}" class="alarm-dropdown-foot">Все клубы →</a>
            </div>
        </div>
        <div id="dz-access-alarm-banner-slot"></div>
    {% endif %}
{% endif %}
