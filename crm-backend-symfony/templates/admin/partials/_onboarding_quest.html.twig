<div class="dz-onboarding-root" id="dz-onboarding-root"
     data-user-id="{{ userId|default('guest') }}"
     data-dz-lbl-lesson-start="Начать"
     data-dz-lbl-lesson-done-mark="✓"
     data-dz-lbl-reset-confirm="Сбросить прогресс обучения?">

    <div class="dz-hud">
        <div class="dz-hud-progress-wrap">
            <div class="dz-hud-progress-bar">
                <div class="dz-hud-progress-fill" data-dz-progress-fill style="width: 0%"></div>
            </div>
            <div class="dz-hud-progress-label">Пройдено: <span data-dz-progress-text>0 / {{ questData.totalLessons|default(0) }}</span></div>
        </div>
        <div class="dz-hud-stat dz-stat-xp" title="Опыт">⚡ <span data-dz-xp>0</span> XP</div>
        <div class="dz-hud-stat dz-stat-streak" title="Дней подряд">🔥 <span data-dz-streak>1</span></div>
        <div class="dz-hud-stat dz-stat-hearts" data-dz-hearts title="Попытки при ошибке"></div>
    </div>

    <div data-dz-view="map" class="dz-map-view">
        <p class="dz-map-lead">
            <strong>Интерактивный тур.</strong> Залька откроет раздел CRM, подсветит кнопку или поле — нажмите его или «Далее».
        </p>
        <div data-dz-tour="lesson-map" data-dz-path class="dz-lesson-path">
            {% set globalLesson = 0 %}
            {% for unit in questData.units|default([]) %}
                <section class="dz-unit">
                    <header class="dz-unit-header" style="--unit-color: {{ unit.color|default('#ff5b2e') }}">
                        <span class="dz-unit-badge">{{ loop.index }}</span>
                        <span class="dz-unit-title">{{ unit.title }}</span>
                    </header>
                    <div class="dz-lesson-list">
                        {% for lesson in unit.lessons|default([]) %}
                            {% set globalLesson = globalLesson + 1 %}
                            {% set isFirst = globalLesson == 1 %}
                            <button type="button"
                                    class="dz-lesson-row{% if isFirst %} dz-lesson-current{% elseif globalLesson > 1 %} dz-lesson-locked{% endif %}"
                                    data-lesson-id="{{ lesson.id }}"
                                    data-lesson-num="{{ globalLesson }}"
                                    {% if not isFirst %}disabled{% endif %}>
                                <span class="dz-lesson-row-num">{{ globalLesson }}</span>
                                <span class="dz-lesson-row-body">
                                    <span class="dz-lesson-row-title">{{ lesson.title }}</span>
                                    <span class="dz-lesson-row-meta">{{ lesson.summary|default('') }}</span>
                                </span>
                                <span class="dz-lesson-row-action">{% if isFirst %}Начать{% else %}🔒{% endif %}</span>
                            </button>
                        {% endfor %}
                    </div>
                </section>
            {% endfor %}
        </div>
        <div class="dz-map-actions">
            <button type="button" data-dz-reset>Сбросить прогресс</button>
        </div>
    </div>
</div>
