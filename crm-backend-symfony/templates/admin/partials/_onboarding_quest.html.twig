<div class="dz-onboarding-root" id="dz-onboarding-root"
     data-user-id="{{ userId|default('guest') }}"
     data-dz-lbl-continue="Продолжить"
     data-dz-lbl-back-map="На карту уроков"
     data-dz-lbl-question="Вопрос"
     data-dz-lbl-correct="Верно!"
     data-dz-lbl-excellent="Отлично!"
     data-dz-lbl-wrong="Не совсем…"
     data-dz-lbl-try-again="Попробуй ещё раз."
     data-dz-lbl-hearts-out=" Сердечки закончились — скоро восстановятся."
     data-dz-lbl-reset-confirm="Начать квест заново? XP и прогресс сбросятся."
     data-dz-lbl-map-left="Выбери урок ниже. Осталось {n} — ты справишься!"
     data-dz-lbl-map-done="Все уроки пройдены! Ты молодец!"
     data-dz-lbl-lesson-done="Урок пройден!"
     data-dz-lbl-proud="гордится тобой!"
     data-dz-lbl-continue-path="Следующий урок"
     data-dz-lbl-path-error="Уроки не загрузились. Обновите страницу (Ctrl+F5)."
     data-dz-lbl-mascot="{{ questData.mascot.name|default('Залька') }}"
     data-dz-lbl-lesson-start="Начать →"
     data-dz-lbl-lesson-done-mark="✓">

    <script type="application/json" id="dz-quest-json" data-dz-quest-json>{{ questDataJson|default('{}')|raw }}</script>

    <template data-dz-celebration-template>
        <div class="dz-celebration">
            <div class="dz-celebration-xp" data-dz-celebration-xp>+15 XP</div>
            <div class="dz-celebration-title">{{ 'Урок пройден!' }}</div>
            <p class="dz-celebration-text" data-dz-celebration-text></p>
            <button type="button" class="dz-btn dz-btn-primary" data-dz-celebration-close>Следующий урок</button>
        </div>
    </template>

    <div class="dz-hud">
        <div class="dz-hud-progress-wrap">
            <div class="dz-hud-progress-bar">
                <div class="dz-hud-progress-fill" data-dz-progress-fill style="width: 0%"></div>
            </div>
            <div class="dz-hud-progress-label">Пройдено уроков: <span data-dz-progress-text>0 / {{ questData.totalLessons|default(0) }}</span></div>
        </div>
        <div class="dz-hud-stat dz-stat-xp" title="Опыт">⚡ <span data-dz-xp>0</span> XP</div>
        <div class="dz-hud-stat dz-stat-streak" title="Дней подряд">🔥 <span data-dz-streak>1</span></div>
        <div class="dz-hud-stat dz-stat-hearts" data-dz-hearts title="Попытки при ошибке"></div>
    </div>

    <canvas class="dz-confetti-canvas d-none" data-dz-confetti aria-hidden="true"></canvas>

    <div data-dz-overlay class="dz-overlay d-none">
        <div data-dz-overlay-content></div>
    </div>

    <div class="dz-lesson-top d-none" data-dz-lesson-bar>
        <button type="button" class="btn btn-sm btn-link text-secondary p-0" data-dz-back-map title="К списку уроков">✕</button>
        <div class="dz-lesson-top-bar">
            <div class="dz-lesson-top-fill" data-dz-lesson-progress style="width: 0%"></div>
        </div>
        <span class="dz-lesson-top-title" data-dz-lesson-title>Урок</span>
    </div>

    <div class="dz-intro-card content-card mb-0 border-0" style="background: rgba(255,91,46,0.08); border-radius: 0;">
        <div class="dz-intro-title">Что это за квест?</div>
        <p class="dz-intro-text mb-2">
            Это <strong>интерактивное обучение CRM</strong> для сотрудников клуба. {{ questData.totalLessons|default(16) }} коротких уроков:
            Залька объясняет разделы CRM, задаёт простые вопросы. За уроки вы получаете XP. Подробный текст — во вкладке «Справочник».
        </p>
        <button type="button" class="dz-btn dz-btn-primary dz-btn-start" data-dz-start-first>
            Начать первый урок: Знакомство
        </button>
    </div>

    <div class="dz-mascot-row" data-dz-mascot-row>
        <div class="dz-mascot-wrap" data-dz-mascot>
            {% include 'admin/partials/_zalka_mascot.html.twig' %}
        </div>
        <div class="dz-speech-bubble" data-dz-bubble>
            <div class="dz-bubble-title" data-dz-bubble-title>{{ questData.mascot.name|default('Залька') }}</div>
            <p class="dz-bubble-text" data-dz-bubble-text">Нажми зелёную кнопку выше или выбери урок в списке ниже.</p>
        </div>
    </div>

    <div data-dz-view="map" class="dz-map-view">
        <div data-dz-path class="dz-lesson-path">
            {% for unit in questData.units|default([]) %}
                <section class="dz-unit">
                    <header class="dz-unit-header" style="--unit-color: {{ unit.color|default('#ff5b2e') }}">
                        <span class="dz-unit-badge">{{ loop.index }}</span>
                        <div>
                            <div class="dz-unit-title">{{ unit.title }}</div>
                            <div class="dz-unit-sub text-secondary small">
                                {% if unit.id == 'start' %}Как устроена CRM и с чего начать смену
                                {% elseif unit.id == 'clients' %}Поиск, карточка и регистрация клиентов
                                {% elseif unit.id == 'leads' %}Заявки и воронка продаж
                                {% elseif unit.id == 'subscriptions' %}Тарифы, выдача и заморозка
                                {% elseif unit.id == 'schedule' %}Занятия и записи на тренировки
                                {% elseif unit.id == 'mobile' %}Приложение клиента и вход по QR
                                {% elseif unit.id == 'finish' %}Касса и завершение обучения
                                {% endif %}
                            </div>
                        </div>
                    </header>
                    <div class="dz-lesson-list">
                        {% for lesson in unit.lessons|default([]) %}
                            {% set isFirst = loop.first and loop.parent.loop.first %}
                            <button type="button"
                                    class="dz-lesson-row{% if isFirst %} dz-lesson-current{% elseif not isFirst %} dz-lesson-locked{% endif %}"
                                    data-lesson-id="{{ lesson.id }}"
                                    {% if not isFirst %}disabled{% endif %}>
                                <span class="dz-lesson-row-icon">{{ lesson.icon|default('📘') }}</span>
                                <span class="dz-lesson-row-body">
                                    <span class="dz-lesson-row-title">{{ lesson.title }}</span>
                                    <span class="dz-lesson-row-meta">Урок {{ loop.index }} · +{{ questData.xpPerLesson|default(15) }} XP</span>
                                </span>
                                <span class="dz-lesson-row-action">{% if isFirst %}Начать →{% else %}🔒{% endif %}</span>
                            </button>
                        {% endfor %}
                    </div>
                </section>
            {% else %}
                <div class="dz-path-empty alert alert-warning mb-0">
                    Уроки не загрузились. Обновите страницу (Ctrl+F5).
                </div>
            {% endfor %}
        </div>
        <div class="dz-map-actions">
            <button type="button" data-dz-reset>Сбросить прогресс</button>
        </div>
    </div>

    <div data-dz-view="lesson" class="d-none">
        <div data-dz-quiz-options class="dz-quiz-options d-none"></div>
        <div class="dz-lesson-footer">
            <button type="button" class="dz-btn dz-btn-primary" data-dz-continue>Продолжить</button>
        </div>
    </div>
</div>
