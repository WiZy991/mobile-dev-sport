{# Залька — спортивный маскот «Доброзал», облако речи — снаружи, над головой #}
<svg class="dz-mascot-svg" viewBox="0 0 140 200" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <defs>
        <linearGradient id="dz-skin" x1="0%" y1="0%" x2="0%" y2="100%">
            <stop offset="0%" stop-color="#ff8a62"/>
            <stop offset="100%" stop-color="#ff5b2e"/>
        </linearGradient>
        <linearGradient id="dz-tank" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#ff6b3d"/>
            <stop offset="100%" stop-color="#e84e1f"/>
        </linearGradient>
        <linearGradient id="dz-band-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#ffcb45"/>
            <stop offset="100%" stop-color="#ffe08a"/>
        </linearGradient>
        <filter id="dz-shadow" x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="0" dy="3" stdDeviation="4" flood-color="#000" flood-opacity="0.3"/>
        </filter>
    </defs>
    <g class="dz-mascot-body" filter="url(#dz-shadow)">
        <ellipse cx="70" cy="194" rx="36" ry="6" fill="rgba(0,0,0,0.22)"/>

        {# Ноги — атлетичные, узкие #}
        <path d="M 58 148 L 52 188 L 62 188 L 66 152 Z" fill="#2a3140"/>
        <path d="M 82 148 L 88 188 L 78 188 L 74 152 Z" fill="#2a3140"/>
        <ellipse cx="57" cy="188" rx="9" ry="5" fill="#1e2430"/>
        <ellipse cx="83" cy="188" rx="9" ry="5" fill="#1e2430"/>

        {# Торс — майка, V-силуэт #}
        <path d="M 48 108 Q 70 98 92 108 L 88 148 L 52 148 Z" fill="url(#dz-tank)"/>
        <path d="M 58 108 L 70 118 L 82 108" stroke="#ff9a7a" stroke-width="2" fill="none" opacity="0.5"/>

        {# Руки #}
        <g class="dz-mascot-arm-left">
            <ellipse cx="42" cy="118" rx="8" ry="11" fill="url(#dz-skin)" transform="rotate(-25 42 118)"/>
            <ellipse cx="36" cy="132" rx="7" ry="6" fill="#ff7a52"/>
        </g>
        <g class="dz-mascot-arm">
            <ellipse cx="98" cy="112" rx="8" ry="11" fill="url(#dz-skin)" transform="rotate(20 98 112)"/>
            {# Гиря #}
            <rect x="104" y="118" width="14" height="8" rx="2" fill="#6b7a94"/>
            <ellipse cx="111" cy="126" rx="12" ry="10" fill="#4a5568"/>
            <ellipse cx="111" cy="126" rx="7" ry="5" fill="#3d4654"/>
        </g>

        {# Голова #}
        <circle cx="70" cy="72" r="36" fill="url(#dz-skin)"/>
        <rect x="34" y="50" width="72" height="14" rx="7" fill="url(#dz-band-grad)"/>
        <text x="70" y="61" text-anchor="middle" font-family="Manrope, sans-serif" font-weight="800" font-size="9" fill="#8b4513">Д</text>

        <circle cx="56" cy="80" r="5" fill="#ff9a7a" opacity="0.45"/>
        <circle cx="84" cy="80" r="5" fill="#ff9a7a" opacity="0.45"/>

        <g class="dz-mascot-eyes">
            <ellipse cx="58" cy="70" rx="8" ry="10" fill="#fff"/>
            <ellipse cx="82" cy="70" rx="8" ry="10" fill="#fff"/>
            <circle cx="60" cy="72" r="4" fill="#1a1f2e"/>
            <circle cx="84" cy="72" r="4" fill="#1a1f2e"/>
            <circle cx="61" cy="70" r="1.5" fill="#fff"/>
            <circle cx="85" cy="70" r="1.5" fill="#fff"/>
        </g>

        <g class="dz-mascot-mouth dz-mouth-neutral">
            <path d="M 62 86 Q 70 91 78 86" stroke="#1a1f2e" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-happy" style="display:none">
            <path d="M 60 84 Q 70 96 80 84" stroke="#1a1f2e" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-excited" style="display:none">
            <ellipse cx="70" cy="88" rx="8" ry="6" fill="#1a1f2e"/>
            <ellipse cx="70" cy="86" rx="5" ry="3" fill="#ff6b6b"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-thinking" style="display:none">
            <circle cx="74" cy="88" r="3" fill="#1a1f2e"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-sad" style="display:none">
            <path d="M 62 90 Q 70 84 78 90" stroke="#1a1f2e" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-celebrate" style="display:none">
            <path d="M 58 82 Q 70 100 82 82" stroke="#1a1f2e" stroke-width="2.5" fill="none" stroke-linecap="round"/>
            <path d="M 54 76 L 58 80 M 86 76 L 82 80" stroke="#1a1f2e" stroke-width="2" stroke-linecap="round"/>
        </g>
    </g>
</svg>
