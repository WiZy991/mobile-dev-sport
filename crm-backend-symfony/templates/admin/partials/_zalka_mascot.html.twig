<svg class="dz-mascot-svg" viewBox="0 0 200 220" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <defs>
        <linearGradient id="dz-body-grad" x1="0%" y1="0%" x2="100%" y2="100%">
            <stop offset="0%" stop-color="#ff7a52"/>
            <stop offset="100%" stop-color="#ff5b2e"/>
        </linearGradient>
        <linearGradient id="dz-band-grad" x1="0%" y1="0%" x2="100%" y2="0%">
            <stop offset="0%" stop-color="#ffcb45"/>
            <stop offset="100%" stop-color="#ffe08a"/>
        </linearGradient>
        <filter id="dz-shadow" x="-20%" y="-20%" width="140%" height="140%">
            <feDropShadow dx="0" dy="4" stdDeviation="6" flood-color="#000" flood-opacity="0.25"/>
        </filter>
    </defs>
    <g class="dz-mascot-body" filter="url(#dz-shadow)">
        <ellipse cx="100" cy="208" rx="52" ry="10" fill="rgba(0,0,0,0.2)"/>
        <ellipse cx="100" cy="130" rx="58" ry="62" fill="url(#dz-body-grad)"/>
        <g class="dz-mascot-arm">
            <ellipse cx="158" cy="118" rx="14" ry="10" fill="#ff6b3d" transform="rotate(25 158 118)"/>
            <rect x="168" y="108" width="28" height="6" rx="3" fill="#8b9cb8"/>
            <rect x="164" y="102" width="8" height="18" rx="3" fill="#6b7a94"/>
            <rect x="192" y="102" width="8" height="18" rx="3" fill="#6b7a94"/>
        </g>
        <ellipse cx="48" cy="125" rx="12" ry="9" fill="#ff6b3d" transform="rotate(-20 48 125)"/>
        <circle cx="100" cy="72" r="48" fill="url(#dz-body-grad)"/>
        <rect x="52" y="48" width="96" height="18" rx="9" fill="url(#dz-band-grad)"/>
        <text x="100" y="61" text-anchor="middle" font-family="Manrope, sans-serif" font-weight="800" font-size="11" fill="#8b4513">Д</text>
        <circle cx="72" cy="82" r="8" fill="#ff9a7a" opacity="0.5"/>
        <circle cx="128" cy="82" r="8" fill="#ff9a7a" opacity="0.5"/>
        <g class="dz-mascot-eyes">
            <ellipse cx="82" cy="74" rx="10" ry="12" fill="#fff"/>
            <ellipse cx="118" cy="74" rx="10" ry="12" fill="#fff"/>
            <circle cx="84" cy="76" r="5" fill="#1a1f2e"/>
            <circle cx="120" cy="76" r="5" fill="#1a1f2e"/>
            <circle cx="86" cy="74" r="2" fill="#fff"/>
            <circle cx="122" cy="74" r="2" fill="#fff"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-neutral">
            <path d="M 88 92 Q 100 98 112 92" stroke="#1a1f2e" stroke-width="3" fill="none" stroke-linecap="round"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-happy" style="display:none">
            <path d="M 86 90 Q 100 104 114 90" stroke="#1a1f2e" stroke-width="3" fill="none" stroke-linecap="round"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-excited" style="display:none">
            <ellipse cx="100" cy="94" rx="10" ry="8" fill="#1a1f2e"/>
            <ellipse cx="100" cy="91" rx="7" ry="4" fill="#ff6b6b"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-thinking" style="display:none">
            <circle cx="106" cy="94" r="4" fill="#1a1f2e"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-sad" style="display:none">
            <path d="M 88 98 Q 100 90 112 98" stroke="#1a1f2e" stroke-width="3" fill="none" stroke-linecap="round"/>
        </g>
        <g class="dz-mascot-mouth dz-mouth-celebrate" style="display:none">
            <path d="M 84 88 Q 100 108 116 88" stroke="#1a1f2e" stroke-width="3" fill="none" stroke-linecap="round"/>
            <path d="M 78 82 L 82 86 M 122 82 L 118 86" stroke="#1a1f2e" stroke-width="2" stroke-linecap="round"/>
        </g>
        <ellipse cx="78" cy="182" rx="16" ry="10" fill="#e84e1f"/>
        <ellipse cx="122" cy="182" rx="16" ry="10" fill="#e84e1f"/>
    </g>
</svg>
