{# Полные стили встроены в HTML — работают даже если /css/admin.css не отдаётся nginx #}
<style>
:root {
    --primary: #ff5b2e;
    --primary-2: #ff7a52;
    --accent: #ffcb45;
    --bg-dark: #15181f;
    --bg-card: rgba(28, 32, 41, 0.82);
    --bg-card-solid: #1c2029;
    --bg-sidebar: rgba(21, 24, 31, 0.92);
    --border: rgba(255, 255, 255, 0.08);
    --text: #f7f6f1;
    --muted: #b6c0d3;
    --radius: 14px;
    --shadow: 0 20px 50px -20px rgba(0, 0, 0, 0.55);
    --gym-bg: url("/uploads/promotions/promo_20260413_041219_bbf840a0.jpg");
}

* { box-sizing: border-box; }

body {
    margin: 0;
    font-family: "Manrope", system-ui, sans-serif;
    font-size: 14px;
    line-height: 1.5;
    color: var(--text);
    background: var(--bg-dark);
    -webkit-font-smoothing: antialiased;
}

.crm-bg-layer {
    position: fixed;
    inset: 0;
    z-index: -2;
    background:
        linear-gradient(125deg, rgba(21, 24, 31, 0.93) 0%, rgba(21, 24, 31, 0.88) 45%, rgba(29, 33, 44, 0.9) 100%),
        var(--gym-bg) center/cover no-repeat fixed;
}

.crm-bg-glow {
    position: fixed;
    inset: 0;
    z-index: -1;
    pointer-events: none;
    background:
        radial-gradient(ellipse 70% 50% at 85% 15%, rgba(255, 91, 46, 0.12), transparent 55%),
        radial-gradient(ellipse 60% 40% at 5% 90%, rgba(255, 203, 69, 0.08), transparent 50%),
        linear-gradient(180deg, transparent 60%, rgba(0, 0, 0, 0.25) 100%);
}

.layout {
    display: flex;
    min-height: 100vh;
}

/* ——— Sidebar ——— */
.sidebar {
    width: 260px;
    flex-shrink: 0;
    background: var(--bg-sidebar);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    position: sticky;
    top: 0;
    height: 100vh;
    overflow: hidden;
}

.sidebar-brand {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 18px 16px;
    border-bottom: 1px solid var(--border);
}

.logo-mark {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    display: grid;
    place-items: center;
    font-weight: 800;
    font-size: 1.1rem;
    color: #fff;
    box-shadow: 0 8px 20px -6px rgba(255, 91, 46, 0.5);
    flex-shrink: 0;
}

.sidebar-brand-title {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: -0.02em;
}

.sidebar-brand-sub {
    font-size: 0.72rem;
    color: var(--muted);
    margin-top: 1px;
}

.sidebar-search {
    padding: 12px 14px;
    border-bottom: 1px solid var(--border);
}

.search-wrap {
    position: relative;
}

.search-wrap i {
    position: absolute;
    left: 10px;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    font-size: 0.85rem;
    pointer-events: none;
}

.search-wrap input {
    padding-left: 2rem !important;
    background: rgba(0, 0, 0, 0.25) !important;
    border-color: var(--border) !important;
    border-radius: 10px !important;
    color: var(--text) !important;
}

.sidebar-user {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 6px 8px;
    padding: 10px 16px;
    font-size: 0.78rem;
    color: var(--muted);
    border-bottom: 1px solid var(--border);
}

.sidebar-user a {
    color: var(--primary);
    text-decoration: none;
    margin-left: auto;
}

.sidebar-nav {
    flex: 1;
    overflow-y: auto;
    padding-bottom: 16px;
}

.menu-section-title {
    padding: 14px 18px 6px;
    font-size: 0.65rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #6b7180;
}

.menu-item {
    display: flex !important;
    align-items: center;
    gap: 10px;
    padding: 9px 14px !important;
    margin: 2px 10px;
    border-radius: 10px;
    color: #c8cdd8 !important;
    text-decoration: none !important;
    font-size: 0.86rem;
    font-weight: 500;
    transition: background 0.15s, color 0.15s, transform 0.12s;
}

.menu-item i {
    font-size: 1rem;
    opacity: 0.75;
    width: 1.25rem;
    text-align: center;
}

.menu-item:hover {
    background: rgba(255, 255, 255, 0.06);
    color: #fff !important;
}

.menu-item.active {
    background: linear-gradient(135deg, var(--primary), var(--primary-2));
    color: #fff !important;
    font-weight: 700;
    box-shadow: 0 6px 18px -4px rgba(255, 91, 46, 0.45);
}

.menu-item.active i { opacity: 1; }

/* ——— Content ——— */
.content {
    flex: 1;
    min-width: 0;
    padding: 26px 32px 48px;
}

.content-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 16px;
    margin-bottom: 24px;
}

.content-header h1,
.content-header .h4 {
    margin: 0;
    font-size: 1.75rem !important;
    font-weight: 800 !important;
    letter-spacing: -0.03em;
}

.content-card {
    background: var(--bg-card);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px 22px;
    box-shadow: var(--shadow);
    margin-bottom: 1rem;
}

.card-section-title,
.text-primary.small.fw-semibold.text-uppercase {
    font-size: 0.7rem !important;
    font-weight: 700 !important;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--primary) !important;
    margin-bottom: 14px;
}

/* ——— Funnel (горизонтальная воронка как раньше, но красивее) ——— */
.crm-funnel {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: wrap !important;
    align-items: center !important;
    gap: 10px !important;
}

.crm-funnel-step {
    display: block !important;
    min-width: 108px;
    padding: 14px 18px !important;
    border-radius: 12px !important;
    background: rgba(38, 43, 52, 0.9) !important;
    border: 1px solid var(--border) !important;
    text-align: center !important;
    text-decoration: none !important;
    color: var(--text) !important;
    transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
}

.crm-funnel-step:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 91, 46, 0.4) !important;
    color: var(--text) !important;
    box-shadow: 0 8px 24px -8px rgba(0, 0, 0, 0.4);
}

.crm-funnel-step.active {
    border-color: var(--primary) !important;
    background: linear-gradient(160deg, rgba(255, 91, 46, 0.2), rgba(38, 43, 52, 0.95)) !important;
    box-shadow: 0 0 0 1px rgba(255, 91, 46, 0.3);
}

.crm-funnel-step .label {
    font-size: 0.72rem;
    color: var(--muted);
    margin-bottom: 4px;
}

.crm-funnel-step .value {
    font-size: 1.5rem;
    font-weight: 800;
    line-height: 1.1;
    color: #fff;
}

.crm-funnel-step .value.text-success { color: #14b88a !important; }

.crm-funnel-arrow {
    color: #5c6478;
    font-size: 1.1rem;
    user-select: none;
}

/* ——— Stats & quick actions ——— */
.crm-stat-card,
.content-card.h-100 {
    transition: transform 0.15s, border-color 0.15s;
}

a.text-reset:hover .content-card {
    transform: translateY(-2px);
    border-color: rgba(255, 91, 46, 0.25);
}

.crm-quick-action {
    display: block;
    text-align: center;
    padding: 1rem 0.75rem;
    border-radius: 12px;
    background: rgba(33, 38, 51, 0.85);
    border: 1px solid var(--border);
    text-decoration: none !important;
    color: var(--text) !important;
    transition: transform 0.15s, border-color 0.15s;
}

.crm-quick-action:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 91, 46, 0.35);
    color: #fff !important;
}

.crm-quick-action .num {
    display: inline-flex;
    width: 26px;
    height: 26px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 700;
    background: rgba(255, 91, 46, 0.15);
    color: var(--primary);
    border: 1px solid rgba(255, 91, 46, 0.35);
    margin-bottom: 8px;
}

/* ——— Source badges ——— */
.crm-source-badge {
    display: inline-block;
    padding: 3px 10px;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
}

.crm-badge-source-site { background: rgba(66, 133, 244, 0.18); color: #8ab4ff; }
.crm-badge-source-instagram { background: rgba(225, 48, 108, 0.18); color: #ff9ecf; }
.crm-badge-source-vk { background: rgba(76, 117, 163, 0.2); color: #a8c8f0; }
.crm-badge-source-telegram { background: rgba(42, 171, 238, 0.18); color: #7dd3ff; }
.crm-badge-source-referral { background: rgba(20, 184, 138, 0.18); color: #5eecc4; }
.crm-badge-source-guest { background: rgba(171, 71, 188, 0.18); color: #e1a8f0; }
.crm-badge-source-support { background: rgba(255, 203, 69, 0.15); color: #ffd666; }
.crm-badge-source-call { background: rgba(0, 188, 212, 0.15); color: #80deea; }
.crm-badge-source-walkin { background: rgba(121, 134, 203, 0.18); color: #b3c0f7; }
.crm-badge-source-other { background: rgba(158, 158, 158, 0.15); color: #bdbdbd; }

.crm-source-chips {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
}

.crm-source-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    border-radius: 999px;
    background: rgba(0, 0, 0, 0.2);
    border: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--muted);
    text-decoration: none !important;
}

.crm-source-chip:hover,
.crm-source-chip.active {
    border-color: var(--primary);
    color: var(--text);
}

.crm-source-chip strong { color: #fff; }

/* ——— Bootstrap overrides ——— */
.form-control, .form-select {
    background: rgba(0, 0, 0, 0.22) !important;
    border-color: var(--border) !important;
    color: var(--text) !important;
    border-radius: 10px !important;
}

.form-control::placeholder {
    color: #aeb8cb !important;
    opacity: 1;
}

.form-text,
.form-label {
    color: #c4cddd !important;
}

.form-control:focus, .form-select:focus {
    border-color: var(--primary) !important;
    box-shadow: 0 0 0 3px rgba(255, 91, 46, 0.15) !important;
}

/* Кастомные select — см. /js/admin-crm-select.js */
.crm-select { position: relative; display: block; width: 100%; }
.crm-select--sm .crm-select__trigger { min-height: 31px; padding: 0.25rem 2rem 0.25rem 0.55rem; font-size: 0.875rem; border-radius: 10px; }
.crm-native-select { position: absolute !important; width: 1px !important; height: 1px !important; padding: 0 !important; margin: 0 !important; border: 0 !important; opacity: 0 !important; pointer-events: none !important; clip: rect(0,0,0,0); overflow: hidden; }
.crm-select__trigger { display: flex; align-items: center; width: 100%; min-height: 38px; padding: 0.45rem 2.1rem 0.45rem 0.75rem; text-align: left; background: rgba(0,0,0,0.22); border: 1px solid var(--border); border-radius: 10px; color: var(--text); font: inherit; cursor: pointer; }
.crm-select__trigger:focus, .crm-select.is-open .crm-select__trigger { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(255,91,46,0.15); }
.crm-select__label { flex: 1; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
.crm-select__chevron { position: absolute; right: 0.65rem; top: 50%; transform: translateY(-50%); font-size: 0.75rem; color: var(--muted); pointer-events: none; }
.crm-select.is-open .crm-select__chevron { transform: translateY(-50%) rotate(180deg); color: var(--primary); }
.crm-select__menu { display: none; position: absolute; left: 0; right: 0; top: calc(100% + 4px); z-index: 1040; max-height: 260px; overflow-y: auto; padding: 0.35rem; background: #1c2029; border: 1px solid var(--border); border-radius: 10px; box-shadow: 0 12px 32px rgba(0,0,0,0.45); }
.crm-select--drop-up .crm-select__menu:not(.crm-select__menu--portal) { top: auto; bottom: calc(100% + 4px); }
.crm-select.is-open .crm-select__menu:not(.crm-select__menu--portal) { display: block; }
.crm-select__menu--portal { display: block; position: fixed; }
.crm-select__option { display: block; width: 100%; padding: 0.45rem 0.65rem; border: none; border-radius: 8px; background: transparent; color: var(--text); font: inherit; font-size: 0.875rem; text-align: left; cursor: pointer; }
.crm-select__option:hover:not(:disabled):not(.is-selected) { background: rgba(255,255,255,0.06); }
.crm-select__option.is-selected { background: rgba(255,91,46,0.18); color: #fff; font-weight: 600; }
.crm-select__option.is-disabled { opacity: 0.45; cursor: not-allowed; }
.crm-select--disabled .crm-select__trigger { opacity: 0.55; cursor: not-allowed; }

.btn-primary {
    background: linear-gradient(135deg, var(--primary), var(--primary-2)) !important;
    border: none !important;
    font-weight: 700;
    border-radius: 10px !important;
    box-shadow: 0 8px 20px -8px rgba(255, 91, 46, 0.5);
}

.btn-primary:hover {
    filter: brightness(1.06);
}

.table-dark {
    --bs-table-bg: transparent;
    --bs-table-hover-bg: rgba(255, 255, 255, 0.03);
    --bs-table-border-color: var(--border);
}

.table-dark thead th {
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--muted);
    font-weight: 700;
    border-bottom: 1px solid var(--border);
}

.text-secondary { color: var(--muted) !important; }

.link-light { color: #e8ecf4 !important; }

.modal-content.bg-dark {
    background: var(--bg-card-solid) !important;
    border-color: var(--border) !important;
}

.crm-alert { border-radius: 12px; }

.h4.mb-0 { font-weight: 800; font-size: 1.65rem !important; }

@media (max-width: 992px) {
    .layout { flex-direction: column; }
    .sidebar { width: 100%; height: auto; position: relative; max-height: 50vh; }
    .content { padding: 16px; }
}

/* ——— Onboarding ——— */
.crm-onboarding-hero h1 { font-size: 2rem !important; font-weight: 800; }
.crm-onboarding-hero p { color: #c8d0de !important; }
.crm-onboarding-banner { border-left: 3px solid var(--primary); }
.dz-dashboard-mascot-img {
    width: 56px;
    height: 56px;
    object-fit: contain;
    flex-shrink: 0;
    background: transparent;
    display: block;
}
.dz-dashboard-mascot {
    width: 48px;
    height: 48px;
    border-radius: 14px;
    background: linear-gradient(135deg, var(--primary), var(--accent));
    display: grid;
    place-items: center;
    font-size: 1.5rem;
    flex-shrink: 0;
}
.crm-onboarding-toc { padding: 1rem 1.1rem; }
.crm-onboarding-toc-list { padding-left: 1.1rem; color: #c8d0de; }
.crm-onboarding-toc-list li { margin-bottom: 0.35rem; }
.crm-onboarding-toc-list a { color: #d4dbe8 !important; text-decoration: none; }
.crm-onboarding-toc-list a:hover { color: var(--primary) !important; }

.crm-onboarding-accordion {
    --bs-accordion-color: #e8ecf4;
    --bs-accordion-bg: transparent;
    --bs-accordion-active-color: #fff;
    --bs-accordion-active-bg: rgba(255, 91, 46, 0.12);
    --bs-accordion-btn-color: #f7f6f1;
    --bs-accordion-btn-bg: rgba(0, 0, 0, 0.15);
    --bs-accordion-btn-focus-box-shadow: none;
    --bs-accordion-border-color: transparent;
    --bs-accordion-inner-border-radius: 12px;
}

.crm-onboarding-accordion .accordion-item {
    background: transparent;
    border: none;
}

.crm-onboarding-accordion .accordion-button {
    background: rgba(0, 0, 0, 0.15) !important;
    color: #f7f6f1 !important;
    font-weight: 700;
    font-size: 1rem;
    box-shadow: none !important;
    border-radius: 12px !important;
}

.crm-onboarding-accordion .accordion-button:not(.collapsed) {
    background: rgba(255, 91, 46, 0.12) !important;
    color: #fff !important;
}

.crm-onboarding-accordion .accordion-button::after { filter: invert(1); }

.crm-onboarding-accordion .accordion-body {
    padding: 1rem 1.25rem 1.25rem;
    color: #e8ecf4 !important;
    background: rgba(0, 0, 0, 0.18);
    border-radius: 0 0 12px 12px;
}

.crm-onboarding-accordion .accordion-body p,
.crm-onboarding-accordion .accordion-body li,
.crm-onboarding-accordion .accordion-body ol,
.crm-onboarding-accordion .accordion-body ul,
.crm-onboarding-accordion .accordion-body span,
.crm-onboarding-accordion .accordion-body strong,
.crm-onboarding-accordion .accordion-body td,
.crm-onboarding-accordion .accordion-body th {
    color: #e8ecf4 !important;
}

.crm-onboarding-accordion .accordion-body .text-secondary {
    color: #b8c0d0 !important;
}

.crm-onboarding-accordion .accordion-body h6,
.crm-onboarding-accordion .accordion-body h6.text-primary {
    color: var(--primary) !important;
}

.crm-onboarding-accordion .accordion-body .table-dark {
    --bs-table-color: #e8ecf4;
    --bs-table-striped-color: #e8ecf4;
}

.crm-onboarding-tip {
    display: flex;
    gap: 10px;
    align-items: flex-start;
    padding: 12px 14px;
    margin-top: 1rem;
    border-radius: 10px;
    background: rgba(255, 91, 46, 0.15);
    border: 1px solid rgba(255, 91, 46, 0.35);
    font-size: 0.875rem;
    color: #f0f2f7 !important;
}

.crm-onboarding-tip span {
    color: #f0f2f7 !important;
}

.crm-onboarding-tip i { color: var(--primary); font-size: 1.1rem; flex-shrink: 0; }
.crm-onboarding-footer { padding: 1.5rem; }
.crm-onboarding-footer .text-secondary { color: #b8c0d0 !important; }
</style>
