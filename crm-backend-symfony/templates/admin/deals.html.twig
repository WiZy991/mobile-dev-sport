{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Сделки{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Сделки (конвертированные лиды)</h1>
        <form method="get" action="{{ path('admin_section', {section: 'deals'}) }}" class="d-flex align-items-center gap-2">
            <input type="date" name="date_from" class="form-control form-control-sm" value="{{ dateFrom|default('') }}" placeholder="С" style="width: auto;">
            <input type="date" name="date_to" class="form-control form-control-sm" value="{{ dateTo|default('') }}" placeholder="По" style="width: auto;">
            <button type="submit" class="btn btn-sm btn-outline-secondary">Фильтр</button>
            {% if dateFrom or dateTo %}<a href="{{ path('admin_section', {section: 'deals'}) }}" class="btn btn-sm btn-outline-secondary">Сбросить</a>{% endif %}
        </form>
    </div>

    <div class="content-card">
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Имя</th>
                    <th>Контакты</th>
                    <th>Дата конвертации</th>
                    <th>Клиент</th>
                </tr>
                </thead>
                <tbody>
                {% for deal in deals %}
                    <tr>
                        <td>{{ deal.id }}</td>
                        <td>{{ deal.name }}</td>
                        <td>{{ deal.phone }} {% if deal.email %}<br><small class="text-secondary">{{ deal.email }}</small>{% endif %}</td>
                        <td>{{ deal.createdAt|date('d.m.Y H:i') }}</td>
                        <td>
                            {% if deal.convertedUser %}
                                <a href="{{ path('admin_client_show', {id: deal.convertedUser.id}) }}" class="btn btn-sm btn-outline-success">Карточка клиента</a>
                            {% else %}
                                <span class="text-secondary">—</span>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="5" class="text-center text-secondary">
                            Пока нет конвертированных сделок. Оформите абонемент лиду со статусом «Пробное прошло».
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
