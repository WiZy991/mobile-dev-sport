{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Клуб «{{ club.name }}»{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">{{ club.name }}</h1>
        <div class="d-flex gap-2">
            {% if online %}
                <span class="badge bg-success align-self-center">шлюз онлайн</span>
            {% elseif club.gatewayLastSeenAt %}
                <span class="badge bg-danger align-self-center">шлюз офлайн ({{ club.gatewayLastSeenAt|date('Y-m-d H:i') }})</span>
            {% else %}
                <span class="badge bg-secondary align-self-center">не подключался</span>
            {% endif %}
            <a href="{{ path('admin_franchise_list') }}" class="btn btn-sm btn-outline-secondary">← Все клубы</a>
        </div>
    </div>

    <div class="content-card mb-3">
        <div class="d-flex flex-wrap align-items-center justify-content-between gap-3">
            <div>
                <div class="small text-secondary">Сейчас в зале (этот клуб)</div>
                <div class="display-6 mb-0 {{ inside|default(0) > 0 ? 'text-success' : 'text-secondary' }}">
                    {{ inside|default(0) }}
                    <span class="fs-6 text-secondary">чел.</span>
                </div>
            </div>
            <div class="small text-secondary" style="max-width: 480px;">
                Учитываются клиенты, у которых сегодня ПОСЛЕДНЕЕ <em>granted</em>-событие — <code>entry</code>
                (и относится к этому клубу). При парном сценарии вход/выход — пара entry → exit убирает клиента из зала.
            </div>
        </div>
        {% if inside_list is defined and inside_list|length > 0 %}
            <hr class="my-3">
            <div class="table-responsive" style="max-height: 280px; overflow-y: auto;">
                <table class="table table-sm table-dark align-middle mb-0">
                    <thead class="sticky-top">
                        <tr>
                            <th>Клиент</th>
                            <th>Телефон</th>
                            <th class="text-end">Зашёл</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for row in inside_list %}
                            <tr>
                                <td><a href="{{ path('admin_client_show', {id: row.user.id}) }}" class="link-light text-decoration-none">{{ row.user.name }}</a></td>
                                <td>{{ row.user.phone }}</td>
                                <td class="text-end">{{ row.entered_at|date('H:i') }}</td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>

    <div class="row g-3">
        <div class="col-lg-7">
            <div class="content-card mb-3">
                <div class="mb-2 text-primary small fw-semibold text-uppercase">Параметры клуба и СКУД</div>
                <form method="post" action="{{ path('admin_franchise_save', {id: club.id}) }}">
                    <div class="row g-2 mb-2">
                        <div class="col-md-7">
                            <label class="form-label small">Название</label>
                            <input type="text" name="name" class="form-control form-control-sm" value="{{ club.name }}">
                        </div>
                        <div class="col-md-5">
                            <label class="form-label small">ID клуба</label>
                            <input type="text" class="form-control form-control-sm" value="{{ club.id }}" disabled>
                        </div>
                        <div class="col-12">
                            <label class="form-label small">Адрес</label>
                            <input type="text" name="address" class="form-control form-control-sm" value="{{ club.address }}">
                        </div>
                    </div>

                    <hr class="border-secondary my-3">

                    <div class="mb-2 text-primary small fw-semibold text-uppercase">PERCo-Web (локальный, в LAN клуба)</div>
                    <p class="small text-secondary">Эти параметры использует <strong>шлюз</strong> внутри клубной сети, а не облачный CRM.</p>
                    <div class="row g-2">
                        <div class="col-md-12">
                            <label class="form-label small">Базовый URL PERCo-Web</label>
                            <input type="text" name="perco_base_url" class="form-control form-control-sm" value="{{ club.percoBaseUrl }}" placeholder="https://192.168.0.10:8443">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Логин API</label>
                            <input type="text" name="perco_login" class="form-control form-control-sm" value="{{ club.percoLogin }}" autocomplete="off">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Пароль API</label>
                            <input type="password" name="perco_password" class="form-control form-control-sm" placeholder="оставьте пустым, чтобы не менять" autocomplete="new-password">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">ID устройства входа (турникета)</label>
                            <input type="number" name="perco_entry_device_id" class="form-control form-control-sm" value="{{ club.percoEntryDeviceId }}" placeholder="например 696590">
                        </div>
                        <div class="col-md-6 d-flex align-items-end">
                            <input type="hidden" name="perco_verify_ssl" value="0">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="perco_verify_ssl" value="1" id="perco_verify_ssl" {{ club.percoVerifySsl ? 'checked' : '' }}>
                                <label class="form-check-label small" for="perco_verify_ssl">Проверять SSL-сертификат PERCo-Web</label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">Сохранить</button>
                    </div>
                </form>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="content-card mb-3">
                <div class="mb-2 text-primary small fw-semibold text-uppercase">Токен шлюза</div>
                <p class="small text-secondary mb-2">Этим токеном ПК-шлюз клуба авторизуется в CRM (<code>Authorization: Bearer …</code>). Скопируйте в <code>config.ini</code> на ПК клуба.</p>
                {% if club.gatewayToken %}
                    <div class="input-group input-group-sm mb-2">
                        <input type="text" id="gatewayTokenField" class="form-control" value="{{ club.gatewayToken }}" readonly>
                        <button type="button" class="btn btn-outline-light" onclick="navigator.clipboard.writeText(document.getElementById('gatewayTokenField').value)">Копировать</button>
                    </div>
                {% else %}
                    <div class="alert alert-warning small mb-2">Токен не сгенерирован — шлюз не сможет подключиться.</div>
                {% endif %}
                <form method="post" action="{{ path('admin_franchise_regenerate_token', {id: club.id}) }}" onsubmit="return confirm('Старый токен сразу перестанет работать. Продолжить?');">
                    <button type="submit" class="btn btn-sm btn-outline-warning w-100">{{ club.gatewayToken ? 'Сгенерировать новый' : 'Сгенерировать токен' }}</button>
                </form>
            </div>

            <div class="content-card mb-3">
                <div class="mb-2 text-primary small fw-semibold text-uppercase">Удалённое управление</div>
                <p class="small text-secondary mb-2">Команда уйдёт шлюзу при ближайшем long-poll (≤ 30 секунд). Если шлюз офлайн — команда останется в очереди до истечения срока (2 минуты).</p>
                <form method="post" action="{{ path('admin_franchise_open_door', {id: club.id}) }}">
                    <input type="text" name="comment" class="form-control form-control-sm mb-2" placeholder="Комментарий (опционально)">
                    <button type="submit" class="btn btn-sm btn-success w-100" {{ (not club.gatewayToken or not club.percoEntryDeviceId) ? 'disabled' : '' }}>
                        Открыть дверь сейчас
                    </button>
                </form>
            </div>

            <div class="content-card">
                <div class="mb-2 text-primary small fw-semibold text-uppercase">Журнал команд (последние)</div>
                {% if recent_commands is empty %}
                    <div class="small text-secondary">пока нет</div>
                {% else %}
                    <div class="table-responsive">
                        <table class="table table-sm table-dark align-middle mb-0">
                            <thead>
                                <tr><th>#</th><th>Тип</th><th>Статус</th><th>Когда</th></tr>
                            </thead>
                            <tbody>
                                {% for c in recent_commands %}
                                <tr>
                                    <td>{{ c.id }}</td>
                                    <td>{{ c.kind }}</td>
                                    <td>
                                        {% set badge = {'pending': 'secondary', 'delivered': 'info', 'done': 'success', 'failed': 'danger', 'expired': 'dark'}[c.status]|default('secondary') %}
                                        <span class="badge bg-{{ badge }}">{{ c.status }}</span>
                                    </td>
                                    <td class="small">{{ c.createdAt|date('H:i:s') }}</td>
                                </tr>
                                {% endfor %}
                            </tbody>
                        </table>
                    </div>
                {% endif %}
            </div>
        </div>
    </div>
{% endblock %}
