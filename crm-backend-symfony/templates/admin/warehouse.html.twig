{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Склад{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Склад</h1>
        <a href="{{ path('admin_section', {section: 'services'}) }}" class="btn btn-sm btn-outline-primary">Управление услугами и товарами</a>
    </div>

    {% if lowStockProducts|default([])|length > 0 %}
    <div class="alert alert-warning mb-3">
        <strong>Низкий остаток:</strong>
        {% for p in lowStockProducts %}
            <a href="{{ path('admin_section', {section: 'services'}) }}?category=goods" class="alert-link">{{ p.name }}</a> ({{ p.quantity ?? 0 }} шт.){% if not loop.last %}, {% endif %}
        {% endfor %}
    </div>
    {% endif %}

    <div class="content-card">
        <div class="mb-2 text-secondary small">Справочник товаров и услуг для продаж</div>
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Категория</th>
                    <th>Цена</th>
                    <th>Остаток</th>
                    <th>Статус</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for p in products %}
                    <tr>
                        <td>{{ p.id }}</td>
                        <td>{{ p.name }}</td>
                        <td>{{ p.category == 'service' ? 'Услуга' : 'Товар' }}</td>
                        <td>{{ p.price|number_format(0, '', ' ') }} ₽</td>
                        <td>
                            {% if p.category == 'goods' %}
                                <form method="post" action="{{ path('admin_product_stock', {id: p.id}) }}" class="d-inline-flex align-items-center gap-1">
                                    <input type="number" name="quantity" class="form-control form-control-sm" value="{{ p.quantity ?? '' }}" min="0" style="width: 70px" placeholder="—">
                                    <button type="submit" class="btn btn-sm btn-outline-secondary py-0">✓</button>
                                </form>
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>
                            <span class="badge {{ p.isActive ? 'bg-success' : 'bg-secondary' }}">
                                {{ p.isActive ? 'В продаже' : 'Выключен' }}
                            </span>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7" class="text-center text-secondary">
                            Добавьте товары и услуги в разделе «Услуги».
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
{% endblock %}
