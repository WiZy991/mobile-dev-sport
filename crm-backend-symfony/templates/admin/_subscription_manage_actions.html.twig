{% if admin_can_mutate() %}
<div class="d-flex flex-column gap-1 align-items-start">
    {% include 'admin/_subscription_freeze_actions.html.twig' with {sub: sub, return_to: return_to|default(null), return_status: return_status|default(null)} %}
    {% if subscription_can_extend(sub) %}
        <form method="post" action="{{ path('admin_subscription_extend', {id: sub.id}) }}" class="d-inline-flex flex-wrap gap-1 align-items-center">
            {% if return_to is defined and return_to %}
                <input type="hidden" name="return_to" value="{{ return_to }}">
            {% endif %}
            {% if return_status is defined and return_status %}
                <input type="hidden" name="return_status" value="{{ return_status }}">
            {% endif %}
            <input type="number" name="days" min="1" max="365" value="30" class="form-control form-control-sm" style="width:4.5rem" required title="Дней продления">
            <button type="submit" class="btn btn-sm btn-outline-primary">Продлить</button>
        </form>
    {% endif %}
    {% if subscription_can_cancel(sub) %}
        <form method="post" action="{{ path('admin_subscription_cancel', {id: sub.id}) }}" class="d-inline" onsubmit="return confirm('Отменить абонемент? Доступ в клуб будет закрыт.');">
            {% if return_to is defined and return_to %}
                <input type="hidden" name="return_to" value="{{ return_to }}">
            {% endif %}
            {% if return_status is defined and return_status %}
                <input type="hidden" name="return_status" value="{{ return_status }}">
            {% endif %}
            <button type="submit" class="btn btn-sm btn-outline-danger">Отменить</button>
        </form>
    {% endif %}
</div>
{% else %}
    —
{% endif %}
