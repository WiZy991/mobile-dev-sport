{% if admin_can_mutate() %}
<div class="sub-mgmt-actions">
    {% if subscription_can_freeze(sub) %}
        {% set maxDays = subscription_freeze_days_left(sub) %}
        {% set defaultDays = maxDays < 7 ? maxDays : 7 %}
        <form method="post" action="{{ path('admin_subscription_freeze', {id: sub.id}) }}" class="sub-mgmt-actions__row">
            {% if return_to is defined and return_to %}
                <input type="hidden" name="return_to" value="{{ return_to }}">
            {% endif %}
            {% if return_status is defined and return_status %}
                <input type="hidden" name="return_status" value="{{ return_status }}">
            {% endif %}
            <input type="number" name="days" min="1" max="{{ maxDays }}" value="{{ defaultDays }}" class="form-control form-control-sm sub-mgmt-actions__days" required title="Дней заморозки">
            <button type="submit" class="btn btn-sm btn-outline-warning sub-mgmt-actions__btn">Заморозить</button>
        </form>
    {% elseif sub.status == 'frozen' %}
        <form method="post" action="{{ path('admin_subscription_unfreeze', {id: sub.id}) }}" class="sub-mgmt-actions__row">
            {% if return_to is defined and return_to %}
                <input type="hidden" name="return_to" value="{{ return_to }}">
            {% endif %}
            {% if return_status is defined and return_status %}
                <input type="hidden" name="return_status" value="{{ return_status }}">
            {% endif %}
            <button type="submit" class="btn btn-sm btn-outline-success sub-mgmt-actions__btn sub-mgmt-actions__btn--wide">Разморозить</button>
        </form>
    {% endif %}

    {% if subscription_can_extend(sub) %}
        <form method="post" action="{{ path('admin_subscription_extend', {id: sub.id}) }}" class="sub-mgmt-actions__row">
            {% if return_to is defined and return_to %}
                <input type="hidden" name="return_to" value="{{ return_to }}">
            {% endif %}
            {% if return_status is defined and return_status %}
                <input type="hidden" name="return_status" value="{{ return_status }}">
            {% endif %}
            <input type="number" name="days" min="1" max="365" value="30" class="form-control form-control-sm sub-mgmt-actions__days" required title="Дней продления">
            <button type="submit" class="btn btn-sm btn-outline-primary sub-mgmt-actions__btn">Продлить</button>
        </form>
    {% endif %}

    {% if subscription_can_cancel(sub) %}
        <form method="post" action="{{ path('admin_subscription_cancel', {id: sub.id}) }}" class="sub-mgmt-actions__row" onsubmit="return confirm('Отменить абонемент? Доступ в клуб будет закрыт.');">
            {% if return_to is defined and return_to %}
                <input type="hidden" name="return_to" value="{{ return_to }}">
            {% endif %}
            {% if return_status is defined and return_status %}
                <input type="hidden" name="return_status" value="{{ return_status }}">
            {% endif %}
            <button type="submit" class="btn btn-sm btn-outline-danger sub-mgmt-actions__btn sub-mgmt-actions__btn--wide">Отменить</button>
        </form>
    {% endif %}

    {% if not subscription_can_freeze(sub) and sub.status != 'frozen' and not subscription_can_extend(sub) and not subscription_can_cancel(sub) %}
        <span class="text-secondary small">—</span>
    {% endif %}
</div>
{% else %}
    —
{% endif %}
