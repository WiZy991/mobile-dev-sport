{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Новый клиент{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Новый клиент</h1>
        <a href="{{ path('admin_section', {section: 'clients'}) }}" class="btn btn-sm btn-outline-secondary">← К списку</a>
    </div>

    <form method="post" action="{{ path('admin_client_new') }}">
        <div class="content-card mb-3">
            <div class="mb-2 text-primary small fw-semibold text-uppercase">Основные данные</div>
            <div class="row g-2">
                <div class="col-md-4">
                    <label class="form-label small">ФИО *</label>
                    <input type="text" name="name" class="form-control form-control-sm" value="{{ formData.name|default('') }}" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Телефон *</label>
                    <input type="text" name="phone" class="form-control form-control-sm" value="{{ formData.phone|default('') }}" required>
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Email *</label>
                    <input type="email" name="email" class="form-control form-control-sm {{ formData|default(null) ? 'is-invalid' : '' }}" value="{{ formData.email|default('') }}" required>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Дата рождения</label>
                    <input type="date" name="date_of_birth" class="form-control form-control-sm" value="{{ formData.date_of_birth|default('') }}">
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Место рождения</label>
                    <input type="text" name="place_of_birth" class="form-control form-control-sm" placeholder="г. Москва" value="{{ formData.place_of_birth|default('') }}">
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Пол</label>
                    <select name="gender" class="form-select form-select-sm">
                        <option value="">—</option>
                        <option value="M" {{ formData.gender|default('') == 'M' ? 'selected' : '' }}>Мужской</option>
                        <option value="F" {{ formData.gender|default('') == 'F' ? 'selected' : '' }}>Женский</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Бонусы</label>
                    <input type="number" name="bonus_points" class="form-control form-control-sm" value="{{ formData.bonus_points|default(0) }}" min="0">
                </div>
                {% if allTags|default([])|length > 0 %}
                <div class="col-12">
                    <label class="form-label small">Теги</label>
                    <div class="d-flex flex-wrap gap-2">
                        {% for tag in allTags %}
                            <label class="mb-0 small"><input type="checkbox" name="tag_ids[]" value="{{ tag.id }}" {% if formData.tag_ids is defined and tag.id in formData.tag_ids %}checked{% endif %}> <span class="badge" style="background-color: {{ tag.color ?? '#6c757d' }}">{{ tag.name }}</span></label>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}
            </div>
        </div>

        <div class="content-card mb-3">
            <div class="mb-2 text-primary small fw-semibold text-uppercase">Паспортные данные (для абонементов)</div>
            <div class="row g-2">
                <div class="col-md-2">
                    <label class="form-label small">Серия паспорта</label>
                    <input type="text" name="passport_series" class="form-control form-control-sm" maxlength="4" placeholder="1234" value="{{ formData.passport_series|default('') }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Номер паспорта</label>
                    <input type="text" name="passport_number" class="form-control form-control-sm" maxlength="6" placeholder="567890" value="{{ formData.passport_number|default('') }}">
                </div>
                <div class="col-md-4">
                    <label class="form-label small">Кем выдан</label>
                    <input type="text" name="passport_issued_by" class="form-control form-control-sm" placeholder="ОУФМС России" value="{{ formData.passport_issued_by|default('') }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Дата выдачи</label>
                    <input type="date" name="passport_issue_date" class="form-control form-control-sm" value="{{ formData.passport_issue_date|default('') }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Код подразделения</label>
                    <input type="text" name="passport_department_code" class="form-control form-control-sm" maxlength="7" placeholder="123-456" value="{{ formData.passport_department_code|default('') }}">
                </div>
                <div class="col-12">
                    <label class="form-label small">Адрес регистрации</label>
                    <input type="text" name="registration_address" class="form-control form-control-sm" placeholder="г. Москва, ул. Примерная, д. 1, кв. 1" value="{{ formData.registration_address|default('') }}">
                </div>
                <div class="col-12">
                    <label class="form-label small">Контакт для экстренной связи</label>
                    <input type="text" name="emergency_contact" class="form-control form-control-sm" placeholder="+7 999 123-45-67, мама Иванова" value="{{ formData.emergency_contact|default('') }}">
                </div>
            </div>
        </div>

        <button type="submit" class="btn btn-primary">Создать клиента</button>
    </form>
{% endblock %}
