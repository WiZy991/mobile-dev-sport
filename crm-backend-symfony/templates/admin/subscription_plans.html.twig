{% extends 'admin/base.html.twig' %}

{% block title %}CRM FitnessClub — Абонементы{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Абонементы</h1>
        <div class="btn-group btn-group-sm">
            <a href="{{ path('admin_section', {section: 'subscriptions'}) }}" class="btn {{ statusFilter == '' ? 'btn-primary' : 'btn-outline-secondary' }}">Все</a>
            <a href="{{ path('admin_section', {section: 'subscriptions'}) }}?status=active" class="btn {{ statusFilter == 'active' ? 'btn-success' : 'btn-outline-secondary' }}">Активные</a>
            <a href="{{ path('admin_section', {section: 'subscriptions'}) }}?status=frozen" class="btn {{ statusFilter == 'frozen' ? 'btn-warning' : 'btn-outline-secondary' }}">Замороженные</a>
            <a href="{{ path('admin_section', {section: 'subscriptions'}) }}?status=expired" class="btn {{ statusFilter == 'expired' ? 'btn-secondary' : 'btn-outline-secondary' }}">Истёкшие</a>
        </div>
    </div>

    <div class="content-card mb-3">
        <div class="mb-2 text-primary small fw-semibold text-uppercase">Тарифные планы</div>
        <form method="post">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small text-secondary">Название</label>
                    <input type="text" name="name" class="form-control form-control-sm" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Описание</label>
                    <input type="text" name="description" class="form-control form-control-sm" placeholder="опционально">
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Цена, ₽</label>
                    <input type="number" step="0.01" name="price" class="form-control form-control-sm" required>
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Длительность (дней)</label>
                    <input type="number" name="duration_days" class="form-control form-control-sm">
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Кол-во посещений</label>
                    <input type="number" name="visits_count" class="form-control form-control-sm">
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Тип</label>
                    <select name="type" class="form-select form-select-sm">
                        <option value="unlimited">Безлимит</option>
                        <option value="limited">Ограниченный</option>
                        <option value="personal">Персональные</option>
                    </select>
                </div>
                <div class="col-md-1">
                    <label class="form-label small text-secondary">&nbsp;</label>
                    <div class="form-check">
                        <input type="checkbox" name="is_popular" value="1" class="form-check-input">
                        <label class="form-check-label small">Популярный</label>
                    </div>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-sm btn-primary w-100">Добавить</button>
                </div>
            </div>
        </form>
    </div>

    <div class="content-card">
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Название</th>
                    <th>Тип</th>
                    <th>Цена</th>
                    <th>Длительность</th>
                    <th>Посещений</th>
                    <th>Заморозка</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for plan in plans %}
                    <tr>
                        <td>{{ plan.id }}</td>
                        <td>
                            {{ plan.name }}
                            {% if plan.isPopular %}<span class="badge bg-warning text-dark ms-1">Популярный</span>{% endif %}
                        </td>
                        <td>{{ plan.type }}</td>
                        <td>{{ plan.price|number_format(0, '', ' ') }} ₽</td>
                        <td>{{ plan.durationDays ?? '—' }}</td>
                        <td>{{ plan.visitsCount ?? '—' }}</td>
                        <td>
                            {% set freezeDays = subscription_freeze_days_for_plan(plan) %}
                            {% if freezeDays > 0 %}
                                {{ freezeDays }} дн.
                            {% else %}
                                <span class="text-secondary">нет</span>
                            {% endif %}
                        </td>
                        <td>
                            <button type="button" class="btn btn-sm btn-outline-secondary" data-bs-toggle="collapse" data-bs-target="#edit-plan-{{ plan.id }}">Изменить</button>
                            <form method="post" action="{{ path('admin_plan_delete', {id: plan.id}) }}" class="d-inline" onsubmit="return confirm('Удалить план «{{ plan.name }}»?');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </td>
                    </tr>
                    <tr class="collapse" id="edit-plan-{{ plan.id }}">
                        <td colspan="8" class="bg-dark py-2">
                            <form method="post" action="{{ path('admin_plan_update', {id: plan.id}) }}" class="row g-2 align-items-end">
                                <div class="col-md-2">
                                    <input type="text" name="name" class="form-control form-control-sm" value="{{ plan.name }}" required placeholder="Название">
                                </div>
                                <div class="col-md-2">
                                    <input type="number" step="0.01" name="price" class="form-control form-control-sm" value="{{ plan.price }}" required placeholder="Цена">
                                </div>
                                <div class="col-md-2">
                                    <input type="number" name="duration_days" class="form-control form-control-sm" value="{{ plan.durationDays ?? '' }}" placeholder="Дней">
                                </div>
                                <div class="col-md-2">
                                    <input type="number" name="visits_count" class="form-control form-control-sm" value="{{ plan.visitsCount ?? '' }}" placeholder="Посещений">
                                </div>
                                <div class="col-md-2">
                                    <select name="type" class="form-select form-select-sm">
                                        <option value="unlimited" {{ plan.type == 'unlimited' ? 'selected' : '' }}>Безлимит</option>
                                        <option value="limited" {{ plan.type == 'limited' ? 'selected' : '' }}>Ограниченный</option>
                                        <option value="personal" {{ plan.type == 'personal' ? 'selected' : '' }}>Персональные</option>
                                    </select>
                                </div>
                                <div class="col-md-1">
                                    <div class="form-check">
                                        <input type="checkbox" name="is_popular" value="1" class="form-check-input" {{ plan.isPopular ? 'checked' : '' }}>
                                        <label class="form-check-label small">Популярный</label>
                                    </div>
                                </div>
                                <div class="col-md-1">
                                    <button type="submit" class="btn btn-sm btn-success">Сохранить</button>
                                </div>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="8" class="text-center text-secondary">
                            Пока нет ни одного абонемента.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

    <div class="content-card mb-3 mt-3">
        <div class="mb-2 text-primary small fw-semibold text-uppercase">Выдать абонемент клиенту</div>
        <div class="alert alert-info py-2 mb-2 small">
            Для выдачи абонемента у клиента должны быть заполнены: паспорт (серия, номер), дата рождения.<br>
            <strong>Заморозка по тарифу:</strong> 1 мес — нет; 3 мес — 14 дн.; 6 мес — 20 дн.; 12 мес — 30 дн. (если поле «Дней заморозки» пустое — подставится автоматически).
        </div>
        <form method="post" action="{{ path('admin_subscription_issue') }}">
            {% if statusFilter %}<input type="hidden" name="return_status" value="{{ statusFilter }}">{% endif %}
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small text-secondary">Клиент</label>
                    <select name="user_id" class="form-select form-select-sm" required>
                        <option value="">Выберите клиента</option>
                        {% for user in users %}
                            <option value="{{ user.id }}">
                                {{ user.name }} ({{ user.phone }}) {% if not user.hasRequiredDataForSubscription %}[данные не заполнены]{% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small text-secondary">Тарифный план</label>
                    <select name="plan_id" class="form-select form-select-sm" required id="issue-plan-select">
                        <option value="">Выберите план</option>
                        {% for plan in plans %}
                            <option value="{{ plan.id }}" data-freeze-days="{{ subscription_freeze_days_for_plan(plan) }}">
                                {{ plan.name }} — {{ plan.price|number_format(0, '', ' ') }} ₽
                                {% set fd = subscription_freeze_days_for_plan(plan) %}
                                {% if fd > 0 %} (заморозка {{ fd }} дн.){% else %} (без заморозки){% endif %}
                            </option>
                        {% endfor %}
                    </select>
                </div>
                {% if clubs is defined and clubs|length > 1 %}
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Клуб абонемента</label>
                    <select name="club_id" class="form-select form-select-sm" required>
                        <option value="">— выберите —</option>
                        {% for c in clubs %}
                            <option value="{{ c.id }}">{{ c.name }}</option>
                        {% endfor %}
                    </select>
                </div>
                {% elseif clubs is defined and clubs|length == 1 %}
                <input type="hidden" name="club_id" value="{{ clubs[0].id }}">
                {% endif %}
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Дата начала</label>
                    <input type="date" name="start_date" class="form-control form-control-sm">
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Всего посещений</label>
                    <input type="number" name="visits_total" class="form-control form-control-sm" placeholder="по плану">
                </div>
                <div class="col-md-2">
                    <label class="form-label small text-secondary">Дней заморозки</label>
                    <input type="number" name="freeze_days_total" id="issue-freeze-days" class="form-control form-control-sm" min="0" placeholder="по тарифу">
                </div>
                <div class="col-md-2 mt-2 mt-md-0">
                    <button type="submit" class="btn btn-sm btn-success w-100">Выдать абонемент</button>
                </div>
            </div>
        </form>
    </div>

    <div class="content-card mt-3">
        <div class="mb-2 text-primary small fw-semibold text-uppercase">Абонементы клиентов</div>
        <div class="table-responsive">
            <table class="table table-sm table-dark align-middle mb-0">
                <thead>
                <tr>
                    <th>ID</th>
                    <th>Клиент</th>
                    <th>План</th>
                    <th>Клуб</th>
                    <th>Статус</th>
                    <th>Период</th>
                    <th>Продажа</th>
                    <th>Посещений</th>
                    <th>Заморозка</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                {% for sub in subscriptions %}
                    <tr id="sub-{{ sub.id }}">
                        <td>{{ sub.id }}</td>
                        <td>
                            <a href="{{ path('admin_client_show', {id: sub.user.id}) }}" class="link-light text-decoration-none">{{ sub.user.name }}</a>
                            ({{ sub.user.phone }})
                        </td>
                        <td>{{ sub.plan.name }}</td>
                        <td>{% if sub.club %}{{ sub.club.name }}{% else %}<span class="text-secondary">Все клубы</span>{% endif %}</td>
                        <td>{{ sub.status }}</td>
                        <td>
                            {{ sub.startDate|date('d.m.Y') }}
                            {% if sub.endDate %}
                                — {{ sub.endDate|date('d.m.Y') }}
                            {% endif %}
                        </td>
                        <td>
                            {% set sale = sub.sales|first %}
                            {% if sale %}
                                <a href="{{ path('admin_section', {section: 'sales'}) }}" class="link-light" title="Продажа #{{ sale.id }}">{{ sale.total|number_format(0, '', ' ') }} ₽</a>
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>
                            {% if sub.visitsTotal is not null %}
                                {{ sub.visitsUsed ?? 0 }} / {{ sub.visitsTotal }}
                            {% else %}
                                —
                            {% endif %}
                        </td>
                        <td>
                            {% include 'admin/_subscription_freeze_info.html.twig' with {sub: sub} %}
                        </td>
                        <td>
                            {% include 'admin/_subscription_freeze_actions.html.twig' with {sub: sub, return_to: 'subscriptions', return_status: statusFilter} %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="10" class="text-center text-secondary">
                            Абонементы клиентам пока не выданы.
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    <script>
        (function () {
            var planSelect = document.getElementById('issue-plan-select');
            var freezeInput = document.getElementById('issue-freeze-days');
            if (!planSelect || !freezeInput) return;
            planSelect.addEventListener('change', function () {
                var opt = planSelect.options[planSelect.selectedIndex];
                var days = opt ? opt.getAttribute('data-freeze-days') : '';
                freezeInput.placeholder = days === '0' ? '0 (нет)' : (days ? days + ' (по тарифу)' : 'по тарифу');
            });
        })();
    </script>
{% endblock %}

