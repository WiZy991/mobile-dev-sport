{% extends 'admin/base.html.twig' %}

{% block title %}CRM Доброзал — Настройки клуба{% endblock %}

{% block body %}
    <div class="content-header">
        <h1 class="h4 mb-0">Настройки клуба</h1>
        <div class="d-flex gap-2">
            <a href="{{ path('admin_franchise_list') }}" class="btn btn-sm btn-outline-info">Франшиза / Шлюзы</a>
            <a href="{{ path('admin_section', {section: 'settings'}) }}" class="btn btn-sm btn-outline-secondary">← Настройки</a>
        </div>
    </div>

    <div class="content-card mb-3">
        <div class="mb-2 text-primary small fw-semibold text-uppercase">Информация о клубе</div>
        <p class="small text-secondary mb-3">Эти данные отображаются клиентам в мобильном приложении: «Мы на карте» / «О клубе», «О сети и контакты», карта. После сохранения перезайдите в приложение или обновите экран.</p>
        <form method="post" action="{{ path('admin_settings_club') }}">
            <div class="row g-2 mb-2">
                <div class="col-md-6">
                    <label class="form-label small">Название клуба</label>
                    <input type="text" name="name" class="form-control form-control-sm" value="{{ club.name }}">
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Телефон</label>
                    <input type="text" name="phone" class="form-control form-control-sm" value="{{ club.phone }}" placeholder="+7 (495) 123-45-67">
                </div>
                <div class="col-12">
                    <label class="form-label small">Адрес</label>
                    <input type="text" name="address" class="form-control form-control-sm" value="{{ club.address }}">
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Email</label>
                    <input type="email" name="email" class="form-control form-control-sm" value="{{ club.email }}">
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Режим работы</label>
                    <input type="text" name="working_hours" class="form-control form-control-sm" value="{{ club.working_hours }}" placeholder="Пн-Пт: 7:00–23:00, Сб-Вс: 9:00–21:00">
                </div>
                <div class="col-12">
                    <label class="form-label small">Удобства (через запятую)</label>
                    <input type="text" name="amenities" class="form-control form-control-sm" value="{{ club.amenities }}" placeholder="Тренажёрный зал, Бассейн, Йога">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Широта</label>
                    <input type="text" name="latitude" class="form-control form-control-sm" value="{{ club.latitude }}">
                </div>
                <div class="col-md-2">
                    <label class="form-label small">Долгота</label>
                    <input type="text" name="longitude" class="form-control form-control-sm" value="{{ club.longitude }}">
                </div>
                <div class="col-12 mt-3">
                    <div class="text-primary small fw-semibold text-uppercase mb-2">Баннер на главной экране приложения</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Заголовок акции / новости</label>
                    <input type="text" name="promo_home_title" class="form-control form-control-sm" value="{{ club.promo_home_title }}" placeholder="СКИДКА 20%!">
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Подзаголовок</label>
                    <input type="text" name="promo_home_subtitle" class="form-control form-control-sm" value="{{ club.promo_home_subtitle }}" placeholder="на все карты 12 и 6 месяцев">
                </div>
            </div>

            <hr class="border-secondary my-3">

            <div class="mb-2 text-primary small fw-semibold text-uppercase">Аренда клуба для тренеров</div>
            <p class="small text-secondary mb-3">Ежемесячная сумма, которую тренер оплачивает в staff-приложении после одобрения регистрации (Альфа-Банк).</p>
            <div class="row g-2 mb-3">
                <div class="col-md-4">
                    <label class="form-label small">Сумма аренды, ₽ / месяц</label>
                    <input type="number" min="0" step="1" name="trainer_rental_amount_rub" class="form-control form-control-sm" value="{{ club.trainer_rental_amount_rub }}">
                </div>
            </div>

            <hr class="border-secondary my-3">

            <div class="mb-2 text-primary small fw-semibold text-uppercase">Документы для покупки абонемента</div>
            <p class="small text-secondary mb-3">
                Эти ссылки показываются клиенту в приложении <strong>перед оплатой абонемента</strong>.
                Укажите документы <strong>владельца клуба (ИП)</strong> — оферту и политику ПДн.
                Не используйте здесь документы WorldCashFit (они уже принимаются при регистрации в приложении).
            </p>
            <div class="row g-2 mb-3">
                <div class="col-12">
                    <label class="form-label small">Договор с клиентами клуба (публичная оферта) *</label>
                    <input type="url" name="offer_url" class="form-control form-control-sm" value="{{ club.offer_url }}" placeholder="https://dobrozal.ru/doc/offer">
                </div>
                <div class="col-12">
                    <label class="form-label small">Политика по обработке персональных данных клуба *</label>
                    <input type="url" name="privacy_url" class="form-control form-control-sm" value="{{ club.privacy_url }}" placeholder="https://dobrozal.ru/doc/privacy">
                </div>
                <div class="col-12">
                    <label class="form-label small">Правила посещения клуба (необязательно)</label>
                    <input type="url" name="visiting_rules_url" class="form-control form-control-sm" value="{{ club.visiting_rules_url }}" placeholder="https://example.ru/rules">
                </div>
                <div class="col-12">
                    <label class="form-label small">Техника безопасности клуба (необязательно)</label>
                    <input type="url" name="safety_rules_url" class="form-control form-control-sm" value="{{ club.safety_rules_url }}" placeholder="https://example.ru/safety">
                </div>
            </div>

            <hr class="border-secondary my-3">

            <div class="mb-2 text-primary small fw-semibold text-uppercase">Магазин в приложении</div>
            <p class="small text-secondary mb-3">Порядок вкладок и вкладка по умолчанию в разделе «Магазин» мобильного приложения.</p>
            <div class="row g-2 mb-3">
                <div class="col-md-6">
                    <label class="form-label small">Порядок вкладок (JSON)</label>
                    <input type="text" name="shop_tab_order" class="form-control form-control-sm" value="{{ club.shop_tab_order }}" placeholder='["subscriptions","services","goods"]'>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Вкладка по умолчанию</label>
                    <select name="shop_default_tab" class="form-select form-select-sm">
                        <option value="subscriptions" {{ club.shop_default_tab == 'subscriptions' ? 'selected' : '' }}>Абонементы</option>
                        <option value="services" {{ club.shop_default_tab == 'services' ? 'selected' : '' }}>Услуги</option>
                        <option value="goods" {{ club.shop_default_tab == 'goods' ? 'selected' : '' }}>Товары</option>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Скрывать пустые вкладки</label>
                    <select name="hide_empty_shop_tabs" class="form-select form-select-sm">
                        <option value="1" {{ club.hide_empty_shop_tabs != '0' ? 'selected' : '' }}>Да</option>
                        <option value="0" {{ club.hide_empty_shop_tabs == '0' ? 'selected' : '' }}>Нет</option>
                    </select>
                </div>
            </div>

            <hr class="border-secondary my-3">

            <div class="mb-2 text-primary small fw-semibold text-uppercase">О сети / контакты (приложение)</div>
            <p class="small text-secondary mb-3">Текст для экрана «О сети и контакты». Соцсети ниже показываются в приложении в блоке «Мы в социальных сетях» (кнопки с иконками). Телефон и email клуба выше используются, если поля переопределения пустые.</p>
            <div class="row g-2 mb-3">
                <div class="col-12">
                    <label class="form-label small">О сети Доброзал</label>
                    <textarea name="network_about" class="form-control form-control-sm" rows="3" placeholder="Кратко о сети клубов…">{{ club.network_about }}</textarea>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Телефон сети (переопределение)</label>
                    <input type="text" name="contact_phone" class="form-control form-control-sm" value="{{ club.contact_phone }}" placeholder="+7 (495) …">
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Email сети (переопределение)</label>
                    <input type="email" name="contact_email" class="form-control form-control-sm" value="{{ club.contact_email }}">
                </div>
            </div>

            <div class="mb-2 text-primary small fw-semibold text-uppercase">Соцсети и ссылки</div>
            <p class="small text-secondary mb-2">Добавьте сколько угодно сетей: выберите тип и вставьте ссылку. Пустые строки при сохранении игнорируются.</p>
            <div id="social-links-rows" class="mb-2">
                {% for link in social_links %}
                    <div class="row g-2 align-items-end mb-2 social-link-row">
                        <div class="col-md-4">
                            <label class="form-label small">Сеть</label>
                            <select name="social_type[]" class="form-select form-select-sm">
                                {% for key, meta in social_catalog %}
                                    <option value="{{ key }}" {% if link.type == key %}selected{% endif %}>{{ meta.label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label small">Ссылка</label>
                            <input type="url" name="social_url[]" class="form-control form-control-sm" value="{{ link.url }}" placeholder="https://…">
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-sm btn-outline-danger w-100 social-remove" title="Удалить">×</button>
                        </div>
                    </div>
                {% else %}
                    <div class="row g-2 align-items-end mb-2 social-link-row">
                        <div class="col-md-4">
                            <label class="form-label small">Сеть</label>
                            <select name="social_type[]" class="form-select form-select-sm">
                                {% for key, meta in social_catalog %}
                                    <option value="{{ key }}">{{ meta.label }}</option>
                                {% endfor %}
                            </select>
                        </div>
                        <div class="col-md-7">
                            <label class="form-label small">Ссылка</label>
                            <input type="url" name="social_url[]" class="form-control form-control-sm" placeholder="https://…">
                        </div>
                        <div class="col-md-1">
                            <button type="button" class="btn btn-sm btn-outline-danger w-100 social-remove" title="Удалить">×</button>
                        </div>
                    </div>
                {% endfor %}
            </div>
            <button type="button" class="btn btn-sm btn-outline-primary mb-3" id="social-add-row">+ Добавить соцсеть</button>

            <template id="social-link-row-template">
                <div class="row g-2 align-items-end mb-2 social-link-row">
                    <div class="col-md-4">
                        <label class="form-label small">Сеть</label>
                        <select name="social_type[]" class="form-select form-select-sm">
                            {% for key, meta in social_catalog %}
                                <option value="{{ key }}">{{ meta.label }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    <div class="col-md-7">
                        <label class="form-label small">Ссылка</label>
                        <input type="url" name="social_url[]" class="form-control form-control-sm" placeholder="https://…">
                    </div>
                    <div class="col-md-1">
                        <button type="button" class="btn btn-sm btn-outline-danger w-100 social-remove" title="Удалить">×</button>
                    </div>
                </div>
            </template>

            <hr class="border-secondary my-3">

            <div class="mb-2 text-primary small fw-semibold text-uppercase">Модули CRM</div>
            <p class="small text-secondary mb-2">Отключённые модули скрываются из меню для всех сотрудников. Базовые разделы (клиенты, расписание, абонементы…) всегда доступны.</p>
            <div class="row g-2 mb-3">
                {% for key, label in club_modules %}
                    <div class="col-md-4">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="enabled_modules[]" value="{{ key }}" id="mod_{{ key }}" {{ key in enabled_modules ? 'checked' : '' }}>
                            <label class="form-check-label small" for="mod_{{ key }}">{{ label }}</label>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <hr class="border-secondary my-3">

            <div class="mb-2 text-primary small fw-semibold text-uppercase">Вход по QR / турникет (СКУД)</div>
            <p class="small text-secondary mb-2">
                Настройка автоматического открытия турникета при сканировании QR-кода из приложения.
                Обычно заполняет технический специалист клуба. После изменений сохраните настройки и нажмите «Проверить подключение».
            </p>
            <input type="hidden" name="perco_enabled" value="0">
            <div class="row g-2 align-items-end">
                <div class="col-12">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" name="perco_enabled" value="1" id="perco_enabled" {{ 'access' in enabled_modules ? 'checked' : '' }}>
                        <label class="form-check-label small" for="perco_enabled">Включить открытие турникета через СКУД</label>
                    </div>
                </div>
                <div class="col-md-6">
                    <label class="form-label small">Адрес сервера СКУД</label>
                    <input type="text" name="perco_base_url" class="form-control form-control-sm" value="{{ club.perco_base_url }}" placeholder="https://192.168.0.10:8443">
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Логин</label>
                    <input type="text" name="perco_login" class="form-control form-control-sm" value="{{ club.perco_login }}" autocomplete="off">
                </div>
                <div class="col-md-3">
                    <label class="form-label small">Пароль</label>
                    <input type="password" name="perco_password" class="form-control form-control-sm" placeholder="Оставьте пустым, чтобы не менять" autocomplete="new-password">
                </div>
                <div class="col-md-4">
                    <label class="form-label small">ID турникета (устройства входа)</label>
                    <input type="text" name="perco_entry_device_id" class="form-control form-control-sm" value="{{ club.perco_entry_device_id }}" inputmode="numeric" placeholder="например 696590">
                </div>
                <div class="col-12">
                    <details class="small text-secondary mt-2">
                        <summary class="text-primary" style="cursor:pointer;">Дополнительные параметры (для техника)</summary>
                        <div class="row g-2 mt-2">
                            <div class="col-12">
                                <input type="hidden" name="perco_verify_ssl" value="0">
                                <div class="form-check">
                                    <input class="form-check-input" type="checkbox" name="perco_verify_ssl" value="1" id="perco_verify_ssl" {{ club.perco_verify_ssl != '0' ? 'checked' : '' }}>
                                    <label class="form-check-label small" for="perco_verify_ssl">Проверять SSL-сертификат сервера</label>
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Номер команды</label>
                                <input type="text" name="perco_cmd_number" class="form-control form-control-sm" value="{{ club.perco_cmd_number }}" inputmode="numeric" placeholder="1">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Тип команды</label>
                                <input type="text" name="perco_cmd_type" class="form-control form-control-sm" value="{{ club.perco_cmd_type }}" inputmode="numeric" placeholder="0">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Значение</label>
                                <input type="text" name="perco_cmd_value" class="form-control form-control-sm" value="{{ club.perco_cmd_value }}" inputmode="numeric" placeholder="3">
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small">Параметр</label>
                                <input type="text" name="perco_cmd_param" class="form-control form-control-sm" value="{{ club.perco_cmd_param }}" inputmode="numeric" placeholder="5000">
                            </div>
                        </div>
                    </details>
                </div>
                <div class="col-12 mt-2 d-flex flex-wrap gap-2">
                    <button type="submit" class="btn btn-primary">Сохранить</button>
                    {% if admin_can_mutate() %}
                    <button type="submit" class="btn btn-outline-secondary btn-sm" formaction="{{ path('admin_perco_test') }}" formmethod="post">Проверить подключение</button>
                    {% endif %}
                </div>
            </div>
        </form>
    </div>
<script>
(() => {
    const rows = document.getElementById('social-links-rows');
    const addBtn = document.getElementById('social-add-row');
    const tpl = document.getElementById('social-link-row-template');
    if (!rows || !addBtn || !tpl) return;

    addBtn.addEventListener('click', () => {
        rows.appendChild(tpl.content.cloneNode(true));
    });
    rows.addEventListener('click', (e) => {
        const btn = e.target.closest('.social-remove');
        if (!btn) return;
        const row = btn.closest('.social-link-row');
        if (!row) return;
        if (rows.querySelectorAll('.social-link-row').length <= 1) {
            row.querySelectorAll('input').forEach((el) => { el.value = ''; });
            return;
        }
        row.remove();
    });
})();
</script>
{% endblock %}
