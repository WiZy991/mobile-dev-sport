{% extends 'admin/base.html.twig' %}

{% block title %}CRM — Новая организация{% endblock %}

{% block body %}
<div class="content-header">
    <h1 class="h4 mb-0">Новая организация</h1>
</div>

<div class="content-card" style="max-width: 640px">
    <form method="post" action="{{ path('admin_platform_organization_new') }}">
        <div class="mb-3">
            <label class="form-label">Название клуба / организации</label>
            <input type="text" name="name" class="form-control" value="{{ name }}" required>
        </div>
        <div class="mb-3">
            <label class="form-label">Slug (латиница, для API и идентификации)</label>
            <input type="text" name="slug" class="form-control" value="{{ slug }}" required pattern="[a-z0-9-]+">
            <div class="form-text">Например: <code>fitpower</code>. Мобильное приложение может передавать заголовок <code>X-Organization-Slug</code>.</div>
        </div>
        <div class="row">
            <div class="col-md-6 mb-3">
                <label class="form-label">Email организации</label>
                <input type="email" name="org_email" class="form-control" value="{{ orgEmail }}" autocomplete="email" required pattern="^[^@\s]+@[^@\s]+\.[^@\s]+$">
            </div>
            <div class="col-md-6 mb-3">
                <label class="form-label">Телефон</label>
                <input type="tel" name="org_phone" class="form-control" value="{{ orgPhone }}" inputmode="tel" maxlength="18" placeholder="+7 (___) ___-__-__" data-phone-mask>
            </div>
        </div>
        <hr>
        <h2 class="h6">Первый администратор CRM</h2>
        <div class="mb-3">
            <label class="form-label">Email для входа</label>
            <input type="email" name="admin_email" class="form-control" value="{{ adminEmail }}" required autocomplete="email" pattern="^[^@\s]+@[^@\s]+\.[^@\s]+$">
        </div>
        <div class="mb-3">
            <label class="form-label">Имя</label>
            <input type="text" name="admin_name" class="form-control" value="{{ adminName }}">
        </div>
        <div class="mb-3">
            <label class="form-label">Пароль</label>
            <input type="password" name="admin_password" class="form-control" required autocomplete="new-password">
        </div>
        <div class="row">
            <div class="col-md-4 mb-3">
                <label class="form-label">Тариф</label>
                <select name="tariff" class="form-select">
                    <option value="demo" {{ tariff == 'demo' ? 'selected' : '' }}>Демо</option>
                    <option value="start" {{ tariff == 'start' ? 'selected' : '' }}>Старт</option>
                    <option value="business" {{ tariff == 'business' ? 'selected' : '' }}>Бизнес</option>
                    <option value="network" {{ tariff == 'network' ? 'selected' : '' }}>Сеть</option>
                </select>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Начало подписки</label>
                <input type="date" name="subscription_starts_at" class="form-control" value="{{ subscriptionStartsAt }}" required>
            </div>
            <div class="col-md-4 mb-3">
                <label class="form-label">Окончание подписки</label>
                <input type="date" name="subscription_ends_at" class="form-control" value="{{ subscriptionEndsAt }}" required>
            </div>
        </div>
        <button type="submit" class="btn btn-primary">Создать организацию</button>
        <a href="{{ path('admin_platform_organizations') }}" class="btn btn-outline-secondary ms-2">Отмена</a>
    </form>
</div>
<script>
(() => {
    const input = document.querySelector('input[data-phone-mask]');
    if (!input) {
        return;
    }

    const formatPhone = (raw) => {
        const digits = raw.replace(/\D/g, '');
        let normalized = digits;
        if (normalized.startsWith('8')) {
            normalized = '7' + normalized.slice(1);
        }
        if (!normalized.startsWith('7')) {
            normalized = '7' + normalized;
        }
        const d = normalized.slice(0, 11);
        const p1 = d.slice(1, 4);
        const p2 = d.slice(4, 7);
        const p3 = d.slice(7, 9);
        const p4 = d.slice(9, 11);

        let out = '+7';
        if (p1) out += ' (' + p1;
        if (p1.length === 3) out += ')';
        if (p2) out += ' ' + p2;
        if (p3) out += '-' + p3;
        if (p4) out += '-' + p4;
        return out;
    };

    const applyMask = () => {
        input.value = formatPhone(input.value);
    };

    input.addEventListener('input', applyMask);
    input.addEventListener('blur', applyMask);
    applyMask();
})();
</script>
{% endblock %}
