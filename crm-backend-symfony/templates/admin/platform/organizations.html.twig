{% extends 'admin/base.html.twig' %}

{% block title %}CRM — Организации{% endblock %}

{% block body %}
<div class="content-header d-flex justify-content-between align-items-center flex-wrap gap-2">
    <h1 class="h4 mb-0">Организации (лицензиаты)</h1>
    <a href="{{ path('admin_platform_organization_new') }}" class="btn btn-sm btn-primary">Новая организация</a>
</div>

<div class="content-card">
    <p class="text-secondary small mb-3">Каждая организация — изолированный кабинет CRM со своими клиентами, клубами и настройками. После создания передайте клиенту URL <code>/admin</code>, email и пароль администратора.</p>
    <div class="table-responsive">
        <table class="table table-sm table-dark align-middle mb-0">
            <thead>
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Slug</th>
                <th>Тариф</th>
                <th>Демо до</th>
                <th>Активна</th>
            </tr>
            </thead>
            <tbody>
            {% for org in organizations %}
                <tr>
                    <td>{{ org.id }}</td>
                    <td>{{ org.name }}</td>
                    <td><code>{{ org.slug }}</code></td>
                    <td>{{ org.tariff }}</td>
                    <td>{{ org.demoUntil ? org.demoUntil|date('d.m.Y') : '—' }}</td>
                    <td>{{ org.isActive ? 'да' : 'нет' }}</td>
                </tr>
            {% else %}
                <tr><td colspan="6" class="text-center text-secondary">Пока нет организаций. Создайте первую для клиента или выполните миграцию.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
