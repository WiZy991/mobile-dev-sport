{% extends 'admin/base.html.twig' %}

{% block title %}CRM — Организации{% endblock %}

{% block body %}
<div class="content-header">
    <h1 class="h4 mb-0">Организации (лицензиаты)</h1>
</div>

<div class="content-card">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap;">
        <a href="{{ path('admin_platform_organization_new') }}" class="btn btn-primary btn-lg" style="display:inline-flex; align-items:center; font-weight:600;">Создать организацию</a>
    </div>
    <p class="text-secondary small mb-3">Каждая организация — изолированный кабинет CRM со своими клиентами, клубами и настройками. После создания передайте клиенту URL <code>/admin</code>, email и пароль администратора.</p>
    <div class="table-responsive">
        <table class="table table-sm table-dark align-middle mb-0">
            <thead>
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Slug</th>
                <th>Тариф</th>
                <th>Подписка</th>
                <th>Активна</th>
                <th class="text-end">Действия</th>
            </tr>
            </thead>
            <tbody>
            {% for org in organizations %}
                <tr>
                    <td>{{ org.id }}</td>
                    <td>{{ org.name }}</td>
                    <td><code>{{ org.slug }}</code></td>
                    <td>{{ org.tariff }}</td>
                    <td>
                        {% if org.subscriptionStartsAt and org.subscriptionEndsAt %}
                            {{ org.subscriptionStartsAt|date('d.m.Y') }} - {{ org.subscriptionEndsAt|date('d.m.Y') }}
                        {% elseif org.subscriptionEndsAt %}
                            до {{ org.subscriptionEndsAt|date('d.m.Y') }}
                        {% else %}
                            —
                        {% endif %}
                    </td>
                    <td>{{ org.isActive ? 'да' : 'нет' }}</td>
                    <td class="text-end">
                        <div class="d-inline-flex gap-2">
                            <form method="post" action="{{ path('admin_platform_organization_toggle_active', {id: org.id}) }}">
                                <button type="submit" class="btn btn-sm {{ org.isActive ? 'btn-outline-warning' : 'btn-outline-success' }}">
                                    {{ org.isActive ? 'Отключить' : 'Включить' }}
                                </button>
                            </form>
                            <form method="post" action="{{ path('admin_platform_organization_delete', {id: org.id}) }}" onsubmit="return confirm('Удалить организацию {{ org.name|e('js') }}? Это действие необратимо.');">
                                <button type="submit" class="btn btn-sm btn-outline-danger">Удалить</button>
                            </form>
                        </div>
                    </td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="7" class="text-center text-secondary py-4">
                        Пока нет организаций.
                        <div class="mt-3">
                            <a href="{{ path('admin_platform_organization_new') }}" class="btn btn-primary">Создать первую организацию</a>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
