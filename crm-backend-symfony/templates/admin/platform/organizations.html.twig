{% extends 'admin/base.html.twig' %}

{% block title %}CRM — Организации{% endblock %}

{% block body %}
<div class="content-header">
    <h1 class="h4 mb-0">Организации (лицензиаты)</h1>
</div>

<div class="content-card">
    <div style="display:flex; align-items:center; gap:12px; margin-bottom:16px; flex-wrap:wrap;">
        <a href="{{ path('admin_platform_organization_new') }}" class="btn btn-primary btn-lg" style="display:inline-flex; align-items:center; font-weight:600;">Создать организацию</a>
        <a href="{{ path('admin_platform_organization_new') }}" class="btn btn-outline-secondary" style="display:inline-flex; align-items:center;">+ Новая организация</a>
    </div>
    <p class="text-secondary small mb-3">Каждая организация — изолированный кабинет CRM со своими клиентами, клубами и настройками. После создания передайте клиенту URL <code>/admin</code>, email и пароль администратора.</p>
    <div class="table-responsive">
        <table class="table table-sm table-dark align-middle mb-0">
            <thead>
            <tr>
                <th>ID</th>
                <th>Название</th>
                <th>Slug</th>
                <th>Тариф</th>
                <th>Демо до</th>
                <th>Активна</th>
            </tr>
            </thead>
            <tbody>
            {% for org in organizations %}
                <tr>
                    <td>{{ org.id }}</td>
                    <td>{{ org.name }}</td>
                    <td><code>{{ org.slug }}</code></td>
                    <td>{{ org.tariff }}</td>
                    <td>{{ org.demoUntil ? org.demoUntil|date('d.m.Y') : '—' }}</td>
                    <td>{{ org.isActive ? 'да' : 'нет' }}</td>
                </tr>
            {% else %}
                <tr>
                    <td colspan="6" class="text-center text-secondary py-4">
                        Пока нет организаций.
                        <div class="mt-3">
                            <a href="{{ path('admin_platform_organization_new') }}" class="btn btn-primary">Создать первую организацию</a>
                        </div>
                    </td>
                </tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
