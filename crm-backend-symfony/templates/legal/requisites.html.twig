{% extends 'legal/base.html.twig' %}

{% block title %}Реквизиты продавца{% endblock %}

{% block body %}
    <style>
        .req-intro {
            color: var(--muted);
            margin-bottom: 1.75rem;
            max-width: 52rem;
        }

        .req-section {
            background: #fff;
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 1.25rem 1.5rem;
            margin-bottom: 1.25rem;
        }

        .req-section h2 {
            margin: 0 0 1rem;
            font-size: 1.15rem;
        }

        .req-table {
            width: 100%;
            border-collapse: collapse;
        }

        .req-table th,
        .req-table td {
            text-align: left;
            vertical-align: top;
            padding: 0.55rem 0;
            border-bottom: 1px solid var(--border);
        }

        .req-table tr:last-child th,
        .req-table tr:last-child td {
            border-bottom: none;
        }

        .req-table th {
            width: 38%;
            color: var(--muted);
            font-weight: 600;
            padding-right: 1rem;
        }

        .req-note {
            margin-top: 1rem;
            font-size: 0.92rem;
            color: var(--muted);
        }

        @media (max-width: 640px) {
            .req-table th,
            .req-table td {
                display: block;
                width: 100%;
                padding: 0.25rem 0;
            }

            .req-table th {
                padding-top: 0.75rem;
            }

            .req-table tr {
