<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>WorldCashFit — CRM и мобильное приложение для фитнес-клубов и студий</title>
    <meta name="description" content="WorldCashFit: учётная система, CRM, мобильное приложение клиента и тренера, онлайн-запись, онлайн-оплата и аналитика для фитнес-клубов, студий йоги, танцев, единоборств и спорта.">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://images.unsplash.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #fafaf7;
            --bg-soft: #f1efe9;
            --bg-card: #ffffff;
            --bg-dark: #15181f;
            --bg-dark-2: #1d212c;
            --text: #15181f;
            --text-on-dark: #f7f6f1;
            --muted: #6b7180;
            --muted-on-dark: #b5bac9;
            --primary: #ff5b2e;
            --primary-2: #ff7a52;
            --primary-soft: #fff1eb;
            --accent: #ffcb45;
            --success: #14b88a;
            --border: #e5e2da;
            --border-dark: rgba(255, 255, 255, 0.12);
            --shadow-sm: 0 2px 6px rgba(21, 24, 31, 0.05);
            --shadow: 0 24px 50px -20px rgba(21, 24, 31, 0.18);
            --shadow-lg: 0 32px 70px -22px rgba(21, 24, 31, 0.32);
        }

        * { box-sizing: border-box; }
        html { scroll-behavior: smooth; }

        body {
            margin: 0;
            font-family: "Manrope", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Arial, sans-serif;
            color: var(--text);
            background: var(--bg);
            line-height: 1.55;
            -webkit-font-smoothing: antialiased;
        }

        a { color: var(--primary); text-decoration: none; }
        img { max-width: 100%; display: block; }

        h1, h2, h3, h4 { font-family: inherit; line-height: 1.15; margin: 0 0 0.6em; }
        h1 { font-size: clamp(2.2rem, 4.6vw, 3.7rem); font-weight: 800; letter-spacing: -0.025em; }
        h2 { font-size: clamp(1.8rem, 3vw, 2.5rem); font-weight: 800; letter-spacing: -0.015em; }
        h3 { font-size: 1.2rem; font-weight: 700; }
        p { margin: 0 0 1em; }

        .container {
            width: min(1200px, calc(100% - 2rem));
            margin: 0 auto;
        }

        /* HEADER */
        .header {
            position: sticky;
            top: 0;
            z-index: 50;
            background: rgba(250, 250, 247, 0.92);
            border-bottom: 1px solid var(--border);
            backdrop-filter: blur(12px);
        }

        .header-inner {
            display: flex;
            align-items: center;
            gap: 1.5rem;
            justify-content: space-between;
            padding: 0.9rem 0;
        }

        .logo {
            display: flex;
            align-items: center;
            gap: 0.6rem;
            font-weight: 800;
            font-size: 1.15rem;
            letter-spacing: 0.4px;
            color: var(--text);
        }

        .logo-mark {
            width: 38px;
            height: 38px;
            border-radius: 11px;
            background: linear-gradient(135deg, var(--primary), var(--accent));
            display: grid;
            place-items: center;
            color: #fff;
            font-weight: 800;
        }

        .nav {
            display: flex;
            gap: 1.4rem;
            font-size: 0.95rem;
        }

        .nav a {
            color: var(--text);
            opacity: 0.75;
            transition: opacity 0.15s ease;
        }

        .nav a:hover { opacity: 1; }

        .header-actions { display: flex; align-items: center; gap: 0.6rem; }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 0.45rem;
            border: none;
            border-radius: 12px;
            padding: 0.78rem 1.2rem;
            font-weight: 700;
            font-size: 0.95rem;
            text-decoration: none;
            cursor: pointer;
            transition: 0.18s ease;
            white-space: nowrap;
            font-family: inherit;
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--primary), var(--primary-2));
            color: #fff;
            box-shadow: 0 12px 24px -10px rgba(255, 91, 46, 0.55);
        }

        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 16px 28px -10px rgba(255, 91, 46, 0.7); }

        .btn-dark {
            background: var(--bg-dark);
            color: var(--text-on-dark);
        }

        .btn-dark:hover { background: #000; }

        .btn-ghost {
            color: var(--text);
            border: 1.5px solid var(--border);
            background: transparent;
        }

        .btn-ghost:hover { background: var(--bg-soft); }

        .btn-ghost-dark {
            color: var(--text-on-dark);
            border: 1.5px solid var(--border-dark);
            background: transparent;
        }

        .btn-ghost-dark:hover { background: rgba(255, 255, 255, 0.06); }

        .btn-lg { padding: 1rem 1.6rem; font-size: 1rem; border-radius: 14px; }

        /* HERO */
        .hero {
            position: relative;
            padding: 4.5rem 0 4rem;
            overflow: hidden;
            background:
                radial-gradient(circle at 90% 10%, var(--primary-soft), transparent 45%),
                radial-gradient(circle at 5% 95%, #fff7d6, transparent 50%),
                var(--bg);
        }

        .hero-grid {
            position: relative;
            z-index: 1;
            display: grid;
            grid-template-columns: 1.1fr 1fr;
            gap: 2.5rem;
            align-items: center;
        }

        .badge-pill {
            display: inline-flex;
            align-items: center;
            gap: 0.45rem;
            font-size: 0.82rem;
            font-weight: 700;
            padding: 0.4rem 0.85rem;
            background: var(--primary-soft);
            color: var(--primary);
            border: 1px solid #ffd5c5;
            border-radius: 999px;
            margin-bottom: 1.1rem;
        }

        .badge-pill .dot {
            width: 8px; height: 8px;
            border-radius: 50%;
            background: var(--primary);
            animation: pulse 1.6s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.4); opacity: 0.6; }
        }

        h1 .accent { color: var(--primary); }

        .lead {
            color: var(--muted);
            font-size: 1.1rem;
            max-width: 56ch;
            margin-bottom: 1.6rem;
        }

        .hero-actions {
            display: flex;
            flex-wrap: wrap;
            gap: 0.7rem;
            margin-bottom: 1.8rem;
        }

        .hero-stats {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 0.7rem;
        }

        .hero-stat {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 0.85rem 1rem;
            box-shadow: var(--shadow-sm);
        }

        .hero-stat strong { display: block; font-size: 1.45rem; font-weight: 800; color: var(--primary); }
        .hero-stat span { color: var(--muted); font-size: 0.85rem; }

        /* HERO IMAGE */
        .hero-photo {
            position: relative;
            border-radius: 28px;
            overflow: hidden;
            min-height: 480px;
            background:
                linear-gradient(140deg, rgba(21, 24, 31, 0.05), rgba(21, 24, 31, 0.45)),
                url("https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=1400&q=80") center/cover no-repeat,
                #2a2f3d;
            box-shadow: var(--shadow-lg);
        }

        .hero-photo::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, transparent 50%, rgba(0, 0, 0, 0.55) 100%);
        }

        .hero-photo-tag {
            position: absolute;
            top: 16px; left: 16px;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(8px);
            border-radius: 999px;
            padding: 0.5rem 0.9rem;
            font-size: 0.78rem;
            font-weight: 700;
            color: var(--text);
            display: flex;
            gap: 0.4rem;
            align-items: center;
        }

        .hero-photo-tag .dot { width: 8px; height: 8px; background: var(--success); border-radius: 50%; }

        .floating-card {
            position: absolute;
            background: var(--bg-card);
            border-radius: 16px;
            padding: 0.85rem 1rem;
            box-shadow: var(--shadow-lg);
            font-size: 0.85rem;
            display: flex;
            align-items: center;
            gap: 0.7rem;
            color: var(--text);
            border: 1px solid var(--border);
        }

        .fc-1 { bottom: 22px; left: -18px; max-width: 250px; }
        .fc-2 { bottom: 90px; right: -16px; max-width: 230px; }

        .fc-icon {
            width: 38px; height: 38px;
            border-radius: 11px;
            display: grid; place-items: center;
            flex-shrink: 0;
        }

        .fc-icon.green { background: rgba(20, 184, 138, 0.13); color: var(--success); }
        .fc-icon.coral { background: var(--primary-soft); color: var(--primary); }

        .fc-title { font-weight: 700; }
        .fc-sub { color: var(--muted); font-size: 0.78rem; }

        /* SECTIONS */
        section.block { padding: 5rem 0; }
        section.block.tight { padding: 3.5rem 0; }
        section.dark {
            background: var(--bg-dark);
            color: var(--text-on-dark);
        }
        section.dark h2, section.dark h3 { color: var(--text-on-dark); }
        section.dark .section-head p { color: var(--muted-on-dark); }
        section.soft { background: var(--bg-soft); }

        .section-head {
            text-align: center;
            max-width: 720px;
            margin: 0 auto 2.6rem;
        }

        .section-head h2 .accent { color: var(--primary); }
        .section-head p {
            color: var(--muted);
            font-size: 1.05rem;
            margin: 0;
        }

        /* INDUSTRIES — image cards */
        .industries {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 0.9rem;
        }

        .industry {
            position: relative;
            border-radius: 18px;
            overflow: hidden;
            min-height: 180px;
            background: #ddd;
            display: flex;
            align-items: flex-end;
            padding: 1rem;
            color: #fff;
            text-decoration: none;
            box-shadow: var(--shadow-sm);
            transition: 0.25s ease;
        }

        .industry:hover { transform: translateY(-3px); box-shadow: var(--shadow); }

        .industry::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(180deg, rgba(0,0,0,0.05) 30%, rgba(0,0,0,0.78) 100%);
            z-index: 1;
        }

        .industry-text {
            position: relative;
            z-index: 2;
        }

        .industry strong { display: block; font-size: 1.05rem; }
        .industry span { color: rgba(255,255,255,0.85); font-size: 0.85rem; }

        .ind-1 { background: url("https://images.unsplash.com/photo-1534438327276-14e5300c3a48?auto=format&fit=crop&w=600&q=70") center/cover; }
        .ind-2 { background: url("https://images.unsplash.com/photo-1545205597-3d9d02c29597?auto=format&fit=crop&w=600&q=70") center/cover; }
        .ind-3 { background: url("https://images.unsplash.com/photo-1518611012118-696072aa579a?auto=format&fit=crop&w=600&q=70") center/cover; }
        .ind-4 { background: url("https://images.unsplash.com/photo-1549719386-74dfcbf7dbed?auto=format&fit=crop&w=600&q=70") center/cover; }
        .ind-5 { background: url("https://images.unsplash.com/photo-1530549387789-4c1017266635?auto=format&fit=crop&w=600&q=70") center/cover; }
        .ind-6 { background: url("https://images.unsplash.com/photo-1534367507873-d2d7e24c797f?auto=format&fit=crop&w=600&q=70") center/cover; }
        .ind-7 { background: url("https://images.unsplash.com/photo-1599058917212-d750089bc07e?auto=format&fit=crop&w=600&q=70") center/cover; }
        .ind-8 { background: url("https://images.unsplash.com/photo-1517838277536-f5f99be501cd?auto=format&fit=crop&w=600&q=70") center/cover; }

        /* FEATURES */
        .features {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1rem;
        }

        .feature {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 18px;
            padding: 1.5rem;
            transition: 0.2s ease;
        }

        .feature:hover { border-color: #d0cdc3; transform: translateY(-2px); box-shadow: var(--shadow); }

        .feature-icon {
            width: 50px; height: 50px;
            border-radius: 14px;
            display: grid; place-items: center;
            margin-bottom: 0.9rem;
            background: var(--primary-soft);
            color: var(--primary);
        }

        .feature p { color: var(--muted); margin: 0; font-size: 0.95rem; }

        /* APPS SECTION */
        .apps {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 3rem;
            align-items: center;
        }

        .apps-info ul {
            list-style: none;
            padding: 0;
            margin: 1.2rem 0 1.6rem;
        }

        .apps-info li {
            position: relative;
            padding: 0.5rem 0 0.5rem 1.9rem;
            color: var(--text);
            opacity: 0.85;
        }

        .apps-info li::before {
            content: "✓";
            position: absolute;
            left: 0;
            top: 0.5rem;
            width: 22px;
            height: 22px;
            border-radius: 50%;
            background: var(--primary);
            color: #fff;
            text-align: center;
            font-weight: 800;
            font-size: 0.78rem;
            line-height: 22px;
        }

        .apps-visual {
            position: relative;
            min-height: 480px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .apps-photo {
            position: absolute;
            inset: 0;
            border-radius: 28px;
            overflow: hidden;
            box-shadow: var(--shadow-lg);
        }

        .apps-photo img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .apps-photo::after {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(140deg, rgba(255, 91, 46, 0.18), rgba(21, 24, 31, 0.4));
        }

        .phone {
            position: relative;
            z-index: 2;
            width: 270px;
            height: 540px;
            background: #15181f;
            border: 8px solid #0e1014;
            border-radius: 42px;
            box-shadow: 0 40px 80px -20px rgba(0,0,0,0.6);
            overflow: hidden;
        }

        .phone::after {
            content: "";
            position: absolute;
            top: 8px;
            left: 50%;
            transform: translateX(-50%);
            width: 90px;
            height: 22px;
            background: #0e1014;
            border-radius: 0 0 14px 14px;
            z-index: 3;
        }

        .phone-screen {
            position: absolute;
            inset: 8px;
            border-radius: 32px;
            background: #fff;
            color: var(--text);
            padding: 38px 16px 16px;
            font-size: 0.78rem;
            overflow: hidden;
        }

        .ph-head {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 0.7rem;
        }

        .ph-title { font-size: 0.95rem; font-weight: 800; }
        .ph-sub { font-size: 0.72rem; color: var(--muted); }

        .ph-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--bg-soft);
            border: 1px solid var(--border);
            border-radius: 12px;
            padding: 0.55rem 0.7rem;
            margin-bottom: 0.4rem;
        }

        .ph-row.active {
            background: var(--primary-soft);
            border-color: #ffd5c5;
        }

        .ph-row strong { font-size: 0.78rem; }
        .ph-row span.t { color: var(--muted); font-size: 0.7rem; display: block; }

        .ph-tag {
            font-size: 0.65rem;
            font-weight: 700;
            padding: 0.18rem 0.45rem;
            border-radius: 999px;
            background: rgba(20, 184, 138, 0.15);
            color: var(--success);
        }

        .ph-tag.coral { background: var(--primary-soft); color: var(--primary); }

        .ph-btn {
            margin-top: 0.7rem;
            background: linear-gradient(135deg, var(--primary), var(--primary-2));
            color: #fff;
            text-align: center;
            padding: 0.65rem;
            border-radius: 10px;
            font-weight: 800;
            font-size: 0.8rem;
        }

        .ph-stat {
            display: flex; justify-content: space-between; align-items: center;
            padding: 0.55rem 0;
            border-bottom: 1px dashed var(--border);
            font-size: 0.78rem;
        }

        .ph-stat:last-child { border-bottom: none; }
        .ph-stat strong { color: var(--primary); }

        /* DASHBOARD MOCK (CRM screenshot) */
        .crm-mock {
            position: relative;
            background: #fff;
            border-radius: 16px;
            border: 1px solid var(--border);
            box-shadow: var(--shadow-lg);
            overflow: hidden;
            color: var(--text);
        }

        .crm-bar {
            display: flex; align-items: center; gap: 0.5rem;
            padding: 0.7rem 0.9rem;
            background: var(--bg-soft);
            border-bottom: 1px solid var(--border);
        }

        .crm-bar .dot {
            width: 11px; height: 11px; border-radius: 50%;
            background: #d4d2cb;
        }

        .crm-bar .dot.r { background: #ff6b6b; }
        .crm-bar .dot.y { background: #ffcb45; }
        .crm-bar .dot.g { background: #14b88a; }

        .crm-body {
            padding: 1.1rem;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 0.9rem;
        }

        .crm-card {
            background: var(--bg-soft);
            border-radius: 12px;
            padding: 0.9rem;
        }

        .crm-card .lbl { color: var(--muted); font-size: 0.78rem; }
        .crm-card .val { font-size: 1.4rem; font-weight: 800; }
        .crm-card .delta { font-size: 0.78rem; color: var(--success); font-weight: 700; }
        .crm-card.coral { background: var(--primary-soft); }
        .crm-card.coral .val { color: var(--primary); }

        .crm-chart {
            grid-column: 1 / -1;
            background: var(--bg-soft);
            border-radius: 12px;
            padding: 0.9rem;
            min-height: 120px;
            display: flex;
            align-items: end;
            gap: 0.4rem;
        }

        .crm-chart .bar {
            flex: 1;
            background: linear-gradient(180deg, var(--primary), var(--accent));
            border-radius: 4px;
            min-height: 20%;
        }

        /* WHY US */
        .benefits {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 1rem;
        }

        .benefit {
            display: flex;
            gap: 1rem;
            padding: 1.1rem;
            background: rgba(255, 255, 255, 0.04);
            border: 1px solid var(--border-dark);
            border-radius: 16px;
        }

        .benefit-num {
            font-size: 1.6rem;
            font-weight: 800;
            color: var(--primary);
            min-width: 40px;
        }

        .benefit p { margin: 0.3rem 0 0; color: var(--muted-on-dark); font-size: 0.95rem; }

        /* NUMBERS */
        .numbers {
            display: grid;
            grid-template-columns: repeat(4, minmax(0, 1fr));
            gap: 1rem;
            text-align: center;
        }

        .num-value {
            font-size: clamp(2rem, 3.5vw, 3rem);
            font-weight: 800;
            color: var(--primary);
            line-height: 1;
        }

        .numbers small { display: block; color: var(--muted-on-dark); margin-top: 0.5rem; font-size: 0.95rem; }

        /* PRICING */
        .pricing {
            display: grid;
            grid-template-columns: repeat(3, minmax(0, 1fr));
            gap: 1.2rem;
        }

        .price-card {
            position: relative;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 22px;
            padding: 1.8rem;
            display: flex;
            flex-direction: column;
            transition: 0.2s ease;
        }

        .price-card:hover { transform: translateY(-3px); box-shadow: var(--shadow); }

        .price-card.featured {
            background: var(--bg-dark);
            color: var(--text-on-dark);
            border-color: var(--bg-dark);
            box-shadow: var(--shadow-lg);
        }

        .price-card.featured .price-name,
        .price-card.featured .price-list { color: var(--muted-on-dark); }
        .price-card.featured .price-list li { border-color: var(--border-dark); }

        .price-card .badge {
            position: absolute;
            top: -12px; right: 18px;
            background: var(--primary);
            color: #fff;
            font-size: 0.75rem;
            font-weight: 800;
            padding: 0.35rem 0.8rem;
            border-radius: 999px;
            box-shadow: 0 8px 18px -6px rgba(255, 91, 46, 0.5);
        }

        .price-name { font-size: 0.85rem; color: var(--muted); text-transform: uppercase; letter-spacing: 0.06em; font-weight: 700; }
        .price-value {
            font-size: 2.4rem;
            font-weight: 800;
            margin: 0.4rem 0 0.1rem;
            letter-spacing: -0.02em;
        }

        .price-value small { font-size: 0.95rem; color: var(--muted); font-weight: 500; }
        .price-card.featured .price-value small { color: var(--muted-on-dark); }

        .price-list {
            list-style: none;
            padding: 0;
            margin: 1.1rem 0 1.6rem;
            color: var(--muted);
            font-size: 0.93rem;
            flex: 1;
        }

        .price-list li {
            padding: 0.55rem 0;
            border-bottom: 1px solid var(--border);
            display: flex;
            gap: 0.55rem;
            align-items: center;
        }

        .price-list li::before {
            content: "✓";
            color: var(--primary);
            font-weight: 800;
        }

        /* FAQ */
        .faq {
            max-width: 820px;
            margin: 0 auto;
        }

        details.q {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: 14px;
            padding: 1.1rem 1.3rem;
            margin-bottom: 0.6rem;
        }

        details.q[open] { border-color: var(--primary); }

        details.q summary {
            cursor: pointer;
            font-weight: 700;
            list-style: none;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 1rem;
            color: var(--text);
        }

        details.q summary::-webkit-details-marker { display: none; }
        details.q summary::after {
            content: "+";
            font-size: 1.6rem;
            color: var(--primary);
            transition: 0.2s;
            line-height: 1;
        }

        details.q[open] summary::after { transform: rotate(45deg); }

        details.q p {
            margin: 0.7rem 0 0;
            color: var(--muted);
        }

        /* CTA + FORM */
        .cta-block {
            position: relative;
            border-radius: 28px;
            overflow: hidden;
            padding: 0;
            background: var(--bg-dark);
            color: var(--text-on-dark);
            display: grid;
            grid-template-columns: 1fr 1.05fr;
        }

        .cta-side {
            position: relative;
            padding: 3rem 2.5rem;
        }

        .cta-side.photo {
            background:
                linear-gradient(140deg, rgba(255, 91, 46, 0.55), rgba(21, 24, 31, 0.6)),
                url("https://images.unsplash.com/photo-1517836357463-d25dfeac3438?auto=format&fit=crop&w=1200&q=80") center/cover no-repeat;
            min-height: 380px;
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
        }

        .cta-side.photo h2 { color: #fff; }
        .cta-side.photo p { color: rgba(255, 255, 255, 0.9); }

        .form-card .form-grid {
            display: grid;
            grid-template-columns: repeat(2, minmax(0, 1fr));
            gap: 0.8rem;
        }

        .form-grid .full { grid-column: 1 / -1; }

        .field label {
            display: block;
            color: var(--muted-on-dark);
            font-size: 0.85rem;
            margin-bottom: 0.3rem;
            font-weight: 500;
        }

        .field input, .field textarea, .field select {
            width: 100%;
            background: var(--bg-dark-2);
            border: 1px solid var(--border-dark);
            color: var(--text-on-dark);
            padding: 0.78rem 0.95rem;
            border-radius: 10px;
            font-family: inherit;
            font-size: 0.95rem;
            transition: 0.15s;
        }

        .field input::placeholder, .field textarea::placeholder { color: var(--muted-on-dark); opacity: 0.6; }

        .field input:focus, .field textarea:focus, .field select:focus {
            outline: none;
            border-color: var(--primary);
        }

        /* FOOTER */
        footer.foot {
            background: var(--bg-dark);
            color: var(--muted-on-dark);
            padding: 4rem 0 2rem;
        }

        .foot-grid {
            display: grid;
            grid-template-columns: 1.4fr 1fr 1fr 1fr;
            gap: 2rem;
            margin-bottom: 2.5rem;
        }

        .foot .logo { color: var(--text-on-dark); }
        .foot h5 {
            color: var(--text-on-dark);
            text-transform: uppercase;
            font-size: 0.78rem;
            letter-spacing: 0.08em;
            margin: 0 0 0.8rem;
        }

        .foot a { display: block; color: var(--muted-on-dark); padding: 0.25rem 0; }
        .foot a:hover { color: var(--primary); }

        .foot-bottom {
            border-top: 1px solid var(--border-dark);
            padding-top: 1.2rem;
            display: flex;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 0.6rem;
            font-size: 0.85rem;
        }

        @media (max-width: 1000px) {
            .nav { display: none; }
            .hero-grid, .apps, .features, .industries, .pricing, .benefits, .numbers, .foot-grid, .cta-block {
                grid-template-columns: 1fr 1fr;
            }
            .hero-grid, .apps, .cta-block { grid-template-columns: 1fr; }
            .hero-photo { min-height: 360px; }
            .apps-visual { min-height: 420px; }
        }

        @media (max-width: 700px) {
            .hero-grid, .apps, .features, .industries, .pricing, .benefits, .form-grid, .foot-grid {
                grid-template-columns: 1fr;
            }
            .numbers { grid-template-columns: 1fr 1fr; }
            .hero { padding: 3rem 0 2rem; }
            section.block { padding: 3rem 0; }
            .floating-card { display: none; }
            .cta-side { padding: 2rem 1.4rem; }
        }
    </style>
</head>
