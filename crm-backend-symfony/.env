# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# CLI / генерация абсолютных URL (локально оставьте localhost). На проде с HTTPS — ваш домен:
# DEFAULT_URI=https://worldcashfit.ru
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> nelmio/cors-bundle ###
# Для продакшена добавьте домен фронта/админки (или приложение по HTTPS).
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|worldcashfit\.ru)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
DATABASE_URL="mysql://app:Wcb12345@!@database:3306/world_fitness?charset=utf8mb4&serverVersion=8.0.32"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> sber id (CRM) ###
SBER_ID_CLIENT_ID=
SBER_ID_CLIENT_SECRET=
SBER_ID_REDIRECT_URI=
SBER_ID_AUTHORIZE_URL=https://id.sber.ru/CSAFront/oidc/authorize.do
SBER_ID_TOKEN_URL=https://oauth.sber.ru/ru/prod/tokens/v2/oidc
# Опционально: OIDC userinfo (если пусто — используются только утверждения id_token)
SBER_ID_USERINFO_URL=
# HTTPS redirect для legacy-потока (верификация перед покупкой в браузере). Совпадает с URL в кабинете Сбер ID:
# https://worldcashfit.ru/api/v1/auth/sber/callback
SBER_ID_MOBILE_REDIRECT_URI=
# PKCE из приложения: redirect_uri для authorize/token — только HTTPS из кабинета (если второй URI в кабинете добавить нельзя).
SBER_ID_NATIVE_REDIRECT_URI=https://worldcashfit.ru/api/v1/auth/sber/callback
# После GET /api/v1/auth/sber/callback бэкенд отдаёт 302 на этот deep link (кастомная схема), чтобы завершился ASWebAuthenticationSession.
SBER_ID_NATIVE_APP_BRIDGE_URI=worldfitness://auth/callback
# Проверка TLS при запросах к id.sber.ru / oauth.sber.ru (1 = да). 0 = отключить только если сеть подменяет HTTPS своим корнем (небезопасно).
SBER_ID_SSL_VERIFY=1
# Требовать верификацию Сбер ID перед покупкой абонемента в API (0/1)
SUBSCRIPTION_REQUIRE_SBER=0
###< sber id (CRM) ###

###> турникет / PERCo (шлюз) ###
# Токен для POST /api/v1/access/entry (и /exit) со стороны ПК/RPi в клубе. Пусто = без проверки (небезопасно в проде).
ACCESS_GATE_TOKEN=
# 1 = CRM пытается открыть PERCo сам (если задано в настройках клуба и сеть allows). 0 = только шлюз в LAN.
PERCO_OPEN_FROM_CRM=1
###< турникет / PERCo (шлюз) ###
