# In all environments, the following files are loaded if they exist,
# the latter taking precedence over the former:
#
#  * .env                contains default values for the environment variables needed by the app
#  * .env.local          uncommitted file with local overrides
#  * .env.$APP_ENV       committed environment-specific defaults
#  * .env.$APP_ENV.local uncommitted environment-specific overrides
#
# Real environment variables win over .env files.
#
# DO NOT DEFINE PRODUCTION SECRETS IN THIS FILE NOR IN ANY OTHER COMMITTED FILES.
# https://symfony.com/doc/current/configuration/secrets.html
#
# Run "composer dump-env prod" to compile .env files for production use (requires symfony/flex >=1.2).
# https://symfony.com/doc/current/best_practices.html#use-environment-variables-for-infrastructure-configuration

###> symfony/framework-bundle ###
APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
# CLI / генерация абсолютных URL (локально оставьте localhost). На проде с HTTPS — ваш домен:
# DEFAULT_URI=https://worldcashfit.ru
DEFAULT_URI=http://localhost
###< symfony/routing ###

###> nelmio/cors-bundle ###
# Для продакшена добавьте домен фронта/админки (или приложение по HTTPS).
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|worldcashfit\.ru)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> doctrine/doctrine-bundle ###
# Format described at https://www.doctrine-project.org/projects/doctrine-dbal/en/latest/reference/configuration.html#connecting-using-a-url
# IMPORTANT: You MUST configure your server version, either here or in config/packages/doctrine.yaml
#
# DATABASE_URL="sqlite:///%kernel.project_dir%/var/data_%kernel.environment%.db"
DATABASE_URL="mysql://app:Wcb12345@!@database:3306/world_fitness?charset=utf8mb4&serverVersion=8.0.32"
# DATABASE_URL="mysql://app:!ChangeMe!@127.0.0.1:3306/app?serverVersion=10.11.2-MariaDB&charset=utf8mb4"
###< doctrine/doctrine-bundle ###

###> sber id (CRM) ###
SBER_ID_CLIENT_ID=
SBER_ID_CLIENT_SECRET=
SBER_ID_REDIRECT_URI=
SBER_ID_AUTHORIZE_URL=https://id.sber.ru/CSAFront/oidc/authorize.do
SBER_ID_TOKEN_URL=https://oauth.sber.ru/ru/prod/tokens/v2/oidc
# Профиль (email/тел/ФИО/паспорт) приходит через GET userinfo + правильный scope и согласия в кабинете Сбер ID.
SBER_ID_USERINFO_URL=https://oauth.sber.ru/ru/prod/sberbankid/v2.1/userinfo
# Пробельный список scope — только то, что реально включено для приложения (иначе авторизация даст ошибку).
SBER_ID_OIDC_SCOPE='openid profile email mobile name birthdate gender maindoc priority_doc'
# HTTPS redirect для legacy-потока (верификация перед покупкой в браузере). Совпадает с URL в кабинете Сбер ID:
# https://worldcashfit.ru/api/v1/auth/sber/callback
SBER_ID_MOBILE_REDIRECT_URI=
# PKCE из приложения: redirect_uri для authorize/token — только HTTPS из кабинета (если второй URI в кабинете добавить нельзя).
SBER_ID_NATIVE_REDIRECT_URI=https://worldcashfit.ru/api/v1/auth/sber/callback
# После GET /api/v1/auth/sber/callback бэкенд отдаёт 302 на этот deep link (кастомная схема), чтобы завершился ASWebAuthenticationSession.
SBER_ID_NATIVE_APP_BRIDGE_URI=worldfitness://auth/callback
# Проверка TLS при запросах к id.sber.ru / oauth.sber.ru (1 = да). 0 = отключить только если сеть подменяет HTTPS своим корнем (небезопасно).
SBER_ID_SSL_VERIFY=1
# Client PKCS12 bundle path inside Docker image (etc/sber/sber_certificate.p12).
# Warning: committing cert/password to git exposes history; rotate secrets after leaks.
SBER_ID_MTLS_PKCS12=/app/etc/sber/sber_certificate.p12
# PKCS12 password: single-quoted value (Compose-safe with leading @).
SBER_ID_MTLS_PKCS12_PASS='@cbIGx^;:859'
# Требовать верификацию Сбер ID перед покупкой абонемента в API (0/1)
SUBSCRIPTION_REQUIRE_SBER=0
# TTL access-токена мобильного API (секунды)
MOBILE_API_ACCESS_TTL=3600
# Лог raw userinfo (0 = выкл.; паспорт в лог не пишется даже при 1)
SBER_USERINFO_LOG=0
###< sber id (CRM) ###

###> турникет / PERCo (шлюз) ###
# Токен для POST /api/v1/access/entry (и /exit) со стороны ПК/RPi в клубе. Пусто = без проверки (небезопасно в проде).
ACCESS_GATE_TOKEN=
# 1 = CRM пытается открыть PERCo сам (если задано в настройках клуба и сеть allows). 0 = только шлюз в LAN.
PERCO_OPEN_FROM_CRM=1
###< турникет / PERCo (шлюз) ###

###> push / FCM (HTTP v1) ###
# Сервисный аккаунт Firebase для отправки push (FCM HTTP v1). Можно указать ПУТЬ к JSON-файлу
# (например /app/etc/fcm/service-account.json) ИЛИ сам JSON строкой. Пусто = push отключён.
FCM_CREDENTIALS_JSON=
# project_id Firebase. Необязательно — берётся из JSON сервисного аккаунта, если не задано.
FCM_PROJECT_ID=
# Устаревший серверный ключ legacy FCM (эндпоинт fcm/send отключён Google в 2024). Не используется.
FCM_SERVER_KEY=
###< push / FCM (HTTP v1) ###

###> alfa acquiring (internet acquiring) ###
# 0 = заглушка app_acquiring_stub через POST /subscriptions/purchase; 1 = реальная оплата через Альфа-Банк
ALFA_ACQUIRING_ENABLED=1

# --- БОЕВАЯ среда (после подключения в Альфа Бизнес) ---
# Документация: https://alfabank.ru/sme/payservice/internet-acquiring/docs/how-to-go-prod-r/
# Шлюз из письма банка: payment.alfabank.ru (логин r-*) или pay.alfabank.ru (без r-)
ALFA_ACQUIRING_API_URL=https://payment.alfabank.ru/payment/rest/
# Логин API-пользователя *-api из боевого ЛК (https://payment.alfabank.ru/lk/login), НЕ -operator
ALFA_ACQUIRING_USERNAME=r-app_55-api
ALFA_ACQUIRING_PASSWORD=jLPvgzMhl1@!
# 643 = RUB на боевом шлюзе; 810 — только для теста alfa.rbsuat.com
ALFA_ACQUIRING_CURRENCY=643

ALFA_ACQUIRING_RETURN_URL=https://worldcashfit.ru/payment/success
ALFA_ACQUIRING_FAIL_URL=https://worldcashfit.ru/payment/fail
ALFA_ACQUIRING_CALLBACK_URL=https://worldcashfit.ru/api/v1/payments/alfa/callback
# Deep link схема для возврата в приложение после оплаты
ALFA_ACQUIRING_APP_BRIDGE_URI=worldfitness://payment/callback
# Время жизни заказа в секундах (20 мин)
ALFA_ACQUIRING_SESSION_TIMEOUT=1200
# 1 = передавать orderBundle для фискализации (54-ФЗ) — обычно включают на проде
ALFA_ACQUIRING_FISCALIZATION=0
# НДС: taxType для orderBundle (0 = без НДС, согласовать с бухгалтерией)
ALFA_ACQUIRING_TAX_TYPE=0
###< alfa acquiring (internet acquiring) ###
