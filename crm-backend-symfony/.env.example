# Шаблон для сервера и локальной разработки.
# Скопируйте: cp .env.example .env  и заполните секреты.
# Файл .env НЕ коммитится в git — на каждом сервере свой.

###> symfony/framework-bundle ###
APP_ENV=prod
APP_SECRET=change_me_generate_random_string
APP_SHARE_DIR=var/share
###< symfony/framework-bundle ###

###> symfony/routing ###
DEFAULT_URI=https://worldcashfit.ru

# Яндекс.Метрика для dobrozal.ru (счётчик подключается после «СОГЛАСЕН» в cookie-баннере)
YANDEX_METRIKA_ID=0
###< symfony/routing ###

###> nelmio/cors-bundle ###
CORS_ALLOW_ORIGIN='^https?://(localhost|127\.0\.0\.1|worldcashfit\.ru)(:[0-9]+)?$'
###< nelmio/cors-bundle ###

###> doctrine/doctrine-bundle ###
DATABASE_URL="mysql://app:change_me@database:3306/world_fitness?charset=utf8mb4&serverVersion=8.0.32"
###< doctrine/doctrine-bundle ###

###> sber id (CRM) ###
SBER_ID_CLIENT_ID=
SBER_ID_CLIENT_SECRET=
SBER_ID_REDIRECT_URI=
SBER_ID_AUTHORIZE_URL=https://id.sber.ru/CSAFront/oidc/authorize.do
SBER_ID_TOKEN_URL=https://oauth.sber.ru/ru/prod/tokens/v2/oidc
SBER_ID_USERINFO_URL=https://oauth.sber.ru/ru/prod/sberbankid/v2.1/userinfo
SBER_ID_OIDC_SCOPE='openid profile email mobile name birthdate gender maindoc priority_doc'
SBER_ID_MOBILE_REDIRECT_URI=
SBER_ID_NATIVE_REDIRECT_URI=https://worldcashfit.ru/api/v1/auth/sber/callback
SBER_ID_NATIVE_APP_BRIDGE_URI=worldfitness://auth/callback
SBER_ID_SSL_VERIFY=1
SBER_ID_MTLS_PKCS12=/app/etc/sber/sber_certificate.p12
SBER_ID_MTLS_PKCS12_PASS=
SUBSCRIPTION_REQUIRE_SBER=0
MOBILE_API_ACCESS_TTL=3600
SBER_USERINFO_LOG=0
###< sber id (CRM) ###

###> турникет / PERCo (шлюз) ###
ACCESS_GATE_TOKEN=
PERCO_OPEN_FROM_CRM=1
###< турникет / PERCo (шлюз) ###

###> push / FCM (HTTP v1) + APNs (iOS) ###
FCM_CREDENTIALS_JSON=
FCM_PROJECT_ID=
FCM_SERVER_KEY=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=co.worldcashbox.WorldFintess
APNS_AUTH_KEY=
APNS_PRODUCTION=1
###< push / FCM (HTTP v1) + APNs (iOS) ###

###> alfa acquiring (internet acquiring) ###
ALFA_ACQUIRING_ENABLED=1
ALFA_ACQUIRING_API_URL=https://payment.alfabank.ru/payment/rest/
ALFA_ACQUIRING_USERNAME=
ALFA_ACQUIRING_PASSWORD=
ALFA_ACQUIRING_CURRENCY=643
ALFA_ACQUIRING_RETURN_URL=https://worldcashfit.ru/payment/success
ALFA_ACQUIRING_FAIL_URL=https://worldcashfit.ru/payment/fail
ALFA_ACQUIRING_CALLBACK_URL=https://worldcashfit.ru/api/v1/payments/alfa/callback
ALFA_ACQUIRING_APP_BRIDGE_URI=worldfitness://payment/callback
ALFA_ACQUIRING_SESSION_TIMEOUT=1200
ALFA_ACQUIRING_FISCALIZATION=0
ALFA_ACQUIRING_TAX_TYPE=0
###< alfa acquiring (internet acquiring) ###

###> sign in with apple (mobile) ###
APPLE_SIGN_IN_CLIENT_ID=co.worldcashbox.WorldFintess
###< sign in with apple (mobile) ###
