# Скопируйте в .env.local и подставьте пароль от MySQL (как в MySQL Workbench).
# Обязательно URL-кодируйте спецсимволы в пароле: @ -> %40, : -> %3A, / -> %2F, # -> %23, ? -> %3F

DATABASE_URL="mysql://root:Wcb12345@!@127.0.0.1:3306/WorldFitness?charset=utf8mb4&serverVersion=8.0.32"

# Перенос данных со старого SQLite (var/data_dev.db и т.п.) в MySQL после миграций схемы:
#   php bin/console app:data:migrate-sqlite-to-mysql --dry-run
#   php bin/console app:data:migrate-sqlite-to-mysql --force
# Опция: --sqlite-path=var/data_dev.db
