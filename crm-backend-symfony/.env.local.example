# Для запуска в Docker (compose.yaml) используйте те же параметры, что и у сервиса database.
DATABASE_URL="mysql://app:app_password@database:3306/world_fitness?charset=utf8mb4&serverVersion=8.0.32"

# Перенос данных со старого SQLite (var/data_dev.db и т.п.) в MySQL после миграций схемы:
#   php bin/console app:data:migrate-sqlite-to-mysql --dry-run
#   php bin/console app:data:migrate-sqlite-to-mysql --force
# Опция: --sqlite-path=var/data_dev.db

# Токен для шлюза турникета (POST /api/v1/access/entry), см. scripts/turnstile_gateway/README.md
#ACCESS_GATE_TOKEN=change_me_long_random
# 0 = открытие двери только локальным скриптом в клубе; 1 = CRM вызывает PERCo (если сеть позволяет)
#PERCO_OPEN_FROM_CRM=1
