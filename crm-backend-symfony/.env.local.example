# Для запуска в Docker (compose.yaml) используйте те же параметры, что и у сервиса database.
DATABASE_URL="mysql://app:app_password@database:3306/world_fitness?charset=utf8mb4&serverVersion=8.0.32"

# Перенос данных со старого SQLite (var/data_dev.db и т.п.) в MySQL после миграций схемы:
#   php bin/console app:data:migrate-sqlite-to-mysql --dry-run
#   php bin/console app:data:migrate-sqlite-to-mysql --force
# Опция: --sqlite-path=var/data_dev.db

# Токен для шлюза турникета (POST /api/v1/access/entry), см. scripts/turnstile_gateway/README.md
#ACCESS_GATE_TOKEN=change_me_long_random
# 0 = открытие двери только локальным скриптом в клубе; 1 = CRM вызывает PERCo (если сеть позволяет)
#PERCO_OPEN_FROM_CRM=1

# Сбер ID — PKCE: HTTPS из кабинета (= redirect_uri к authorize/token); deep link после GET callback на сервере.
#SBER_ID_NATIVE_REDIRECT_URI=https://worldcashfit.ru/api/v1/auth/sber/callback
#SBER_ID_NATIVE_APP_BRIDGE_URI=worldfitness://auth/callback
#SBER_ID_USERINFO_URL=https://oauth.sber.ru/ru/prod/sberbankid/v2.1/userinfo
# SBER_ID_OIDC_SCOPE задаёт пробелами разделённые scope (должны быть включены в кабинете Сбер ID), см. WorldFitness/instruction.txt
#SBER_ID_OIDC_SCOPE=
# mTLS PKCS#12: в .env задан путь в Docker `/app/etc/sber/sber_certificate.p12` (файл в репозитории). На хосте без Docker переопределите:
#SBER_ID_MTLS_PKCS12=/absolute/path/to/crm-backend-symfony/etc/sber/sber_certificate.p12
#SBER_ID_MTLS_PKCS12_PASS=

# Email-уведомления клиентам (напоминания, расписание, акции)
# Без SMTP_HOST письма идут через PHP mail() — в Docker обычно не работает.
#MAIL_ENABLED=1
#MAIL_FROM=noreply@worldcashfit.ru
#MAIL_FROM_NAME=WorldCashFit
#SMTP_HOST=smtp.yandex.ru
#SMTP_PORT=587
#SMTP_ENCRYPTION=tls
#SMTP_USER=noreply@worldcashfit.ru
#SMTP_PASSWORD=пароль_или_пароль_приложения
