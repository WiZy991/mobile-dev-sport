<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/fc_background"
    android:orientation="vertical">

    <include layout="@layout/include_staff_appbar" />

    <HorizontalScrollView
        android:id="@+id/scheduleDayStrip"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/fc_surface"
        android:paddingVertical="8dp"
        android:scrollbars="none"
        android:visibility="gone">

        <LinearLayout
            android:id="@+id/scheduleDaysContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="8dp" />
    </HorizontalScrollView>

    <LinearLayout
        android:id="@+id/clientsSearchBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/fc_surface"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="12dp"
        android:visibility="gone">

        <EditText
            android:id="@+id/clientsSearchInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:hint="Имя, email или телефон"
            android:inputType="text"
            android:textColor="@color/fc_text"
            android:textColorHint="@color/fc_text_secondary" />

        <Button
            android:id="@+id/clientsSearchButton"
            style="@style/StaffAppButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="Найти" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/workContentView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="4dp"
                android:textColor="@color/fc_text"
                android:textSize="16sp" />

            <LinearLayout
                android:id="@+id/workListContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="vertical" />

            <TextView
                android:id="@+id/workStatusView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:textColor="@color/fc_text_secondary"
                android:textSize="13sp"
                android:visibility="gone" />
        </LinearLayout>
    </ScrollView>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottomNavigation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/fc_surface"
        app:itemIconTint="@color/fc_primary"
        app:itemTextColor="@color/fc_primary"
        app:menu="@menu/bottom_nav_menu" />
</LinearLayout>
